<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ════════════════════════════════════════════════════════════════════
         LIGHT THEME PALETTE
         Toutes les couleurs et brushes thémables du thème clair.
         Doit exposer LES MÊMES CLÉS que Colors.Dark.xaml.
         ════════════════════════════════════════════════════════════════════ -->

    <!-- ══ SURFACES — Color resources ══════════════════════════════════════ -->
    <Color x:Key="C_Surface0">#F2F2F7</Color>
    <Color x:Key="C_Surface1">#FFFFFF</Color>
    <Color x:Key="C_Surface2">#F8F8FB</Color>
    <Color x:Key="C_Surface3">#ECECF2</Color>
    <Color x:Key="C_Surface4">#E0E0EA</Color>
    <Color x:Key="C_Border1">#D8D8E4</Color>
    <Color x:Key="C_Text1">#101020</Color>
    <Color x:Key="C_Text2">#404060</Color>
    <Color x:Key="C_Text3">#8080A0</Color>

    <!-- ══ SURFACES — Brushes ══════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="Surface0" Color="#F2F2F7" />
    <SolidColorBrush x:Key="Surface1" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Surface2" Color="#F8F8FB" />
    <SolidColorBrush x:Key="Surface3" Color="#ECECF2" />
    <SolidColorBrush x:Key="Surface4" Color="#E0E0EA" />
    <SolidColorBrush x:Key="Border1" Color="#D8D8E4" />
    <SolidColorBrush x:Key="Text1" Color="#101020" />
    <SolidColorBrush x:Key="Text2" Color="#404060" />
    <SolidColorBrush x:Key="Text3" Color="#8080A0" />

    <!-- ══ SIDEBAR / HERO — Gradients verticaux ═══════════════════════════ -->
    <LinearGradientBrush x:Key="SidebarGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFFFFF" Offset="0" />
        <GradientStop Color="#F2F2F7" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="HeroOverlay" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#E6FFFFFF" Offset="0" />
        <GradientStop Color="#80F8F8FB" Offset="0.5" />
        <GradientStop Color="#00FFFFFF" Offset="1" />
    </LinearGradientBrush>

    <!-- Hero card — fond clair lavandé (HomeView) -->
    <Color x:Key="C_HeroBgStart">#EFEAFF</Color>
    <Color x:Key="C_HeroBgMid">#D8CDFF</Color>

    <!-- Hero overlay gauche (HomeView) : dégradé gauche-droite par-dessus le hero -->
    <Color x:Key="C_HeroOverlayLeft0">#F2FFFFFF</Color>
    <Color x:Key="C_HeroOverlayLeft1">#CCF8F8FB</Color>
    <Color x:Key="C_HeroOverlayLeft2">#80F8F8FB</Color>

    <!-- Hero "montagnes" silhouettes — versions douces lavandées (HomeView) -->
    <Color x:Key="C_MountainFar">#1AC0B5E0</Color>
    <Color x:Key="C_MountainMid">#CCB0A4D8</Color>
    <Color x:Key="C_MountainNear">#F5A89BD0</Color>
    <Color x:Key="C_MountainSilhouette">#CC9E91C8</Color>
    <SolidColorBrush x:Key="MountainFarBrush" Color="#1AC0B5E0" />
    <SolidColorBrush x:Key="MountainMidBrush" Color="#CCB0A4D8" />
    <SolidColorBrush x:Key="MountainNearBrush" Color="#F5A89BD0" />
    <SolidColorBrush x:Key="MountainSilhouetteBrush" Color="#CC9E91C8" />

    <!-- Topbar HomeView (overlay au-dessus du fond) -->
    <Color x:Key="C_TopbarBg">#E6FFFFFF</Color>

    <!-- News card overlay bottom : en light, voile foncé conservé pour assurer
         la lisibilité du titre blanc par-dessus une image héro variable -->
    <Color x:Key="C_NewsCardOverlay">#E0202030</Color>

    <!-- Bordure ombre fine sur les cards -->
    <Color x:Key="C_ShadowEdge">#1A000000</Color>
    <SolidColorBrush x:Key="ShadowEdge" Color="#1A000000" />

    <!-- ══ OVERLAYS NEUTRES — pour les zones SUR fond accent (header chat) ══
         Le fond restant accent (violet/coloré), on garde du blanc translucide
         car le contenu est posé sur une couleur saturée → blanc lit mieux. -->
    <SolidColorBrush x:Key="OnAccentChip" Color="#22FFFFFF" />
    <SolidColorBrush x:Key="OnAccentChipBorder" Color="#30FFFFFF" />
    <SolidColorBrush x:Key="OnAccentChipStrong" Color="#33FFFFFF" />
    <SolidColorBrush x:Key="OnAccentBorderStrong" Color="#66FFFFFF" />
    <SolidColorBrush x:Key="OnAccentSubtle" Color="#1AFFFFFF" />
    <SolidColorBrush x:Key="OnAccentText" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="OnAccentTextSoft" Color="#CCFFFFFF" />
    <SolidColorBrush x:Key="OnAccentTextMuted" Color="#99FFFFFF" />

    <!-- "Hover row" générique (rangée de liste qui s'assombrit au survol en light) -->
    <SolidColorBrush x:Key="HoverRowBg" Color="#0A000000" />

    <!-- ══ TOAST / NOTIFICATION ════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="ToastTitle" Color="#101020" />
    <SolidColorBrush x:Key="ToastBody" Color="#606080" />
    <Color x:Key="C_ToastShadow">#404060</Color>

    <!-- ══ MAINWINDOW — bannière "Serveur hors ligne" flottante ═══════════
         Reste sur tons sombres pour être bien visible (alerte). -->
    <Color x:Key="C_OfflineBannerStart">#CC2A2440</Color>
    <Color x:Key="C_OfflineBannerEnd">#CC3D2A6A</Color>
    <SolidColorBrush x:Key="OfflineBannerText" Color="#F0F0FF" />

    <!-- ══ SETTINGS — accent color picker actif ═══════════════════════════ -->
    <SolidColorBrush x:Key="ColorSwatchSelectedRing" Color="#101020" />

</ResourceDictionary>