<UserControl x:Class="Minark.Client.Views.Pages.RegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:beh="clr-namespace:Minark.Client.Behaviors"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern">

    <UserControl.Resources>

        <!-- Plasma orbs register (teinte rose/emerald pour différencier) -->
        <Storyboard x:Key="ROb1" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="RPlasma1Trans" Storyboard.TargetProperty="X"
                             From="-70" To="110" Duration="0:0:9">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="RPlasma1Trans" Storyboard.TargetProperty="Y"
                             From="-50" To="90" Duration="0:0:12">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="ROb2" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="RPlasma2Trans" Storyboard.TargetProperty="X"
                             From="80" To="-90" Duration="0:0:11">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="RPlasma2Trans" Storyboard.TargetProperty="Y"
                             From="60" To="-80" Duration="0:0:8">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Rotation logo register -->
        <Storyboard x:Key="RLogSpin" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="RLogoGrad" Storyboard.TargetProperty="Angle"
                             From="0" To="360" Duration="0:0:5" />
        </Storyboard>
        <Storyboard x:Key="RLogPulse" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="RLogoScale" Storyboard.TargetProperty="ScaleX"
                             From="1.0" To="1.06" Duration="0:0:2.5">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="RLogoScale" Storyboard.TargetProperty="ScaleY"
                             From="1.0" To="1.06" Duration="0:0:2.5">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="RGlowPulse" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="RCoreLogo"
                             Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                             From="18" To="50" Duration="0:0:2.2">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Slide-in form -->
        <Storyboard x:Key="RFormIn">
            <DoubleAnimation Storyboard.TargetName="RFormTranslate" Storyboard.TargetProperty="X"
                             From="-80" To="0" Duration="0:0:0.7">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="RFormPanel" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.6" />
        </Storyboard>

        <!-- Brand text -->
        <Storyboard x:Key="RBrandIn">
            <DoubleAnimation Storyboard.TargetName="RBrandText" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:1.0" BeginTime="0:0:0.3" />
            <DoubleAnimation Storyboard.TargetName="RBrandTranslate" Storyboard.TargetProperty="Y"
                             From="20" To="0" Duration="0:0:0.8" BeginTime="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Stagger champs register -->
        <Storyboard x:Key="RF1">
            <DoubleAnimation Storyboard.TargetName="RF1Panel" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.35" BeginTime="0:0:0.45" />
            <DoubleAnimation Storyboard.TargetName="RF1Trans" Storyboard.TargetProperty="Y"
                             From="12" To="0" Duration="0:0:0.3" BeginTime="0:0:0.45">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="RF2">
            <DoubleAnimation Storyboard.TargetName="RF2Panel" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.35" BeginTime="0:0:0.55" />
            <DoubleAnimation Storyboard.TargetName="RF2Trans" Storyboard.TargetProperty="Y"
                             From="12" To="0" Duration="0:0:0.3" BeginTime="0:0:0.55">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="RF3">
            <DoubleAnimation Storyboard.TargetName="RF3Panel" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.35" BeginTime="0:0:0.65" />
            <DoubleAnimation Storyboard.TargetName="RF3Trans" Storyboard.TargetProperty="Y"
                             From="12" To="0" Duration="0:0:0.3" BeginTime="0:0:0.65">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="RF4">
            <DoubleAnimation Storyboard.TargetName="RF4Panel" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.35" BeginTime="0:0:0.75" />
            <DoubleAnimation Storyboard.TargetName="RF4Trans" Storyboard.TargetProperty="Y"
                             From="12" To="0" Duration="0:0:0.3" BeginTime="0:0:0.75">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="RF5">
            <DoubleAnimation Storyboard.TargetName="RF5Panel" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.35" BeginTime="0:0:0.85" />
            <DoubleAnimation Storyboard.TargetName="RF5Trans" Storyboard.TargetProperty="Y"
                             From="12" To="0" Duration="0:0:0.3" BeginTime="0:0:0.85">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource ROb1}" />
            <BeginStoryboard Storyboard="{StaticResource ROb2}" />
            <BeginStoryboard Storyboard="{StaticResource RLogSpin}" />
            <BeginStoryboard Storyboard="{StaticResource RLogPulse}" />
            <BeginStoryboard Storyboard="{StaticResource RGlowPulse}" />
            <BeginStoryboard Storyboard="{StaticResource RFormIn}" />
            <BeginStoryboard Storyboard="{StaticResource RBrandIn}" />
            <BeginStoryboard Storyboard="{StaticResource RF1}" />
            <BeginStoryboard Storyboard="{StaticResource RF2}" />
            <BeginStoryboard Storyboard="{StaticResource RF3}" />
            <BeginStoryboard Storyboard="{StaticResource RF4}" />
            <BeginStoryboard Storyboard="{StaticResource RF5}" />
        </EventTrigger>
    </UserControl.Triggers>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="380" />
        </Grid.ColumnDefinitions>

        <!-- ══ BRAND PANEL register ══════════════════════════════════════════ -->
        <Border Grid.Column="0" x:Name="RBrandPanel" ClipToBounds="True">
            <Border.Background>
                <SolidColorBrush Color="{DynamicResource C_Surface1}" />
            </Border.Background>
            <Grid>
                <!-- Plasma orbs rose/emerald -->
                <Canvas IsHitTestVisible="False">
                    <Ellipse Canvas.Left="-40" Canvas.Top="-30" Width="480" Height="480" Opacity="0.07">
                        <Ellipse.RenderTransform>
                            <TranslateTransform x:Name="RPlasma1Trans" />
                        </Ellipse.RenderTransform>
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="{DynamicResource C_Accent2}" Offset="0" />
                                <GradientStop Color="{DynamicResource C_Accent1}" Offset="0.6" />
                                <GradientStop Color="Transparent" Offset="1" />
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <Ellipse Canvas.Right="-80" Canvas.Bottom="-20" Width="380" Height="380" Opacity="0.06">
                        <Ellipse.RenderTransform>
                            <TranslateTransform x:Name="RPlasma2Trans" />
                        </Ellipse.RenderTransform>
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="{DynamicResource C_AccentSoft}" Offset="0" />
                                <GradientStop Color="Transparent" Offset="1" />
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                </Canvas>

                <!-- Canvas réseau neuronal (code-behind) -->
                <Canvas x:Name="NeuralCanvas" ClipToBounds="True" />

                <!-- Centre : logo "+" avec couronne de nœuds -->
                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">

                    <!-- Halo externe -->
                    <Ellipse Width="300" Height="300" HorizontalAlignment="Center" VerticalAlignment="Center"
                             Opacity="0.08">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="{DynamicResource C_Accent2}" Offset="0.4" />
                                <GradientStop Color="Transparent" Offset="1" />
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>

                    <!-- Logo central : "+" -->
                    <Border x:Name="RCoreLogo" Width="80" Height="80" CornerRadius="0"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="RLogoScale" ScaleX="1" ScaleY="1" CenterX="40" CenterY="40" />
                        </Border.RenderTransform>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <LinearGradientBrush.RelativeTransform>
                                    <RotateTransform x:Name="RLogoGrad" CenterX="0.5" CenterY="0.5" />
                                </LinearGradientBrush.RelativeTransform>
                                <GradientStop Color="{DynamicResource C_Accent2}" Offset="0" />
                                <GradientStop Color="{DynamicResource C_Accent1}" Offset="0.5" />
                                <GradientStop Color="{DynamicResource C_AccentSoft}" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="{DynamicResource C_Accent2}" BlurRadius="28"
                                              ShadowDepth="0" Opacity="0.85" />
                        </Border.Effect>
                        <Grid>
                            <Border CornerRadius="0" Margin="0,0,0,40" Opacity="0.25">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="White" Offset="0" />
                                        <GradientStop Color="Transparent" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <TextBlock Text="M" FontSize="38" FontWeight="Black"
                                       Foreground="{DynamicResource OnAccentText}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Margin="0,0,0,0">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="White" BlurRadius="10" ShadowDepth="0" Opacity="0.35" />
                                </TextBlock.Effect>
                            </TextBlock>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Brand text register -->
                <StackPanel x:Name="RBrandText" VerticalAlignment="Bottom" HorizontalAlignment="Center"
                            Margin="0,0,0,52" Opacity="0">
                    <StackPanel.RenderTransform>
                        <TranslateTransform x:Name="RBrandTranslate" Y="20" />
                    </StackPanel.RenderTransform>
                    <TextBlock Text="Rejoignez Minark" FontSize="30" FontWeight="Black"
                               HorizontalAlignment="Center">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="{DynamicResource C_Accent2}" Offset="0" />
                                <GradientStop Color="{DynamicResource C_Text1}" Offset="0.5" />
                                <GradientStop Color="{DynamicResource C_AccentSoft}" Offset="1" />
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                        <TextBlock.Effect>
                            <DropShadowEffect Color="{DynamicResource C_Accent2}" BlurRadius="18"
                                              ShadowDepth="0" Opacity="0.5" />
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock Text="Gratuit, pour toujours." FontSize="13"
                               Foreground="{DynamicResource Text3}" HorizontalAlignment="Center"
                               Margin="0,6,0,0" FontStyle="Italic" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ FORM PANEL register ════════════════════════════════════════════ -->
        <Border x:Name="RFormPanel" Grid.Column="1"
                Background="{DynamicResource Surface1}"
                BorderBrush="{DynamicResource Border1}"
                BorderThickness="1,0,0,0" Opacity="0">
            <Border.RenderTransform>
                <TranslateTransform x:Name="RFormTranslate" X="-80" />
            </Border.RenderTransform>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="36,32" VerticalAlignment="Center">

                    <TextBlock Text="Créer un compte" FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource Text1}" Margin="0,0,0,4" />
                    <TextBlock Text="Remplissez les informations ci-dessous"
                               Foreground="{DynamicResource Text2}" FontSize="13" Margin="0,0,0,24" />

                    <ui:InfoBar Title="{Binding ErrorMessage, Mode=OneWay}" Severity="Error"
                                IsOpen="{Binding HasError, Mode=OneWay}" IsClosable="False" Margin="0,0,0,12" />
                    <ui:InfoBar Title="{Binding SuccessMessage, Mode=OneWay}" Severity="Success"
                                IsOpen="{Binding HasSuccess, Mode=OneWay}" IsClosable="False" Margin="0,0,0,12" />

                    <!-- Field 1 -->
                    <StackPanel x:Name="RF1Panel" Opacity="0">
                        <StackPanel.RenderTransform>
                            <TranslateTransform x:Name="RF1Trans" Y="12" />
                        </StackPanel.RenderTransform>
                        <TextBlock Text="Nom d'utilisateur" Foreground="{DynamicResource Text2}"
                                   FontSize="12" Margin="0,0,0,6" />
                        <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14" />
                    </StackPanel>

                    <!-- Field 2 -->
                    <StackPanel x:Name="RF2Panel" Opacity="0">
                        <StackPanel.RenderTransform>
                            <TranslateTransform x:Name="RF2Trans" Y="12" />
                        </StackPanel.RenderTransform>
                        <TextBlock Text="Adresse email" Foreground="{DynamicResource Text2}"
                                   FontSize="12" Margin="0,0,0,6" />
                        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14" />
                    </StackPanel>

                    <!-- Field 3 -->
                    <StackPanel x:Name="RF3Panel" Opacity="0">
                        <StackPanel.RenderTransform>
                            <TranslateTransform x:Name="RF3Trans" Y="12" />
                        </StackPanel.RenderTransform>
                        <TextBlock Text="Mot de passe" Foreground="{DynamicResource Text2}"
                                   FontSize="12" Margin="0,0,0,6" />
                        <PasswordBox x:Name="PasswordBox"
                                     beh:PasswordBoxBehavior.BoundPassword="{Binding Password, Mode=TwoWay}"
                                     Margin="0,0,0,14" />
                    </StackPanel>

                    <!-- Field 4 -->
                    <StackPanel x:Name="RF4Panel" Opacity="0">
                        <StackPanel.RenderTransform>
                            <TranslateTransform x:Name="RF4Trans" Y="12" />
                        </StackPanel.RenderTransform>
                        <TextBlock Text="Confirmer le mot de passe" Foreground="{DynamicResource Text2}"
                                   FontSize="12" Margin="0,0,0,6" />
                        <PasswordBox x:Name="ConfirmPasswordBox"
                                     beh:PasswordBoxBehavior.BoundPassword="{Binding ConfirmPassword, Mode=TwoWay}"
                                     Margin="0,0,0,24" />
                    </StackPanel>

                    <ProgressBar IsIndeterminate="True" Height="2" Margin="0,0,0,12"
                                 Visibility="{Binding IsLoading, Mode=OneWay, Converter={StaticResource BoolToVis}}" />

                    <!-- Field 5 -->
                    <StackPanel x:Name="RF5Panel" Opacity="0">
                        <StackPanel.RenderTransform>
                            <TranslateTransform x:Name="RF5Trans" Y="12" />
                        </StackPanel.RenderTransform>
                        <Button Content="Créer mon compte" Command="{Binding RegisterCommand}"
                                Style="{StaticResource AccentBtn}"
                                HorizontalAlignment="Stretch" Height="38" />
                    </StackPanel>

                    <Separator Margin="0,20" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Déjà inscrit ? " Foreground="{DynamicResource Text2}"
                                   FontSize="12" VerticalAlignment="Center" />
                        <ui:HyperlinkButton Content="Se connecter" Command="{Binding GoToLoginCommand}" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>