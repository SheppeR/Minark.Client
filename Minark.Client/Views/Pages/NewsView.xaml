<UserControl
    x:Class="Minark.Client.Views.Pages.NewsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:beh="clr-namespace:Minark.Client.Behaviors"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    xmlns:viewModels="clr-namespace:Minark.Client.ViewModels.Pages"
    x:Name="ThisControl">

    <Grid>
        <Grid.Background>
            <SolidColorBrush Color="{DynamicResource C_Surface0}" />
        </Grid.Background>

        <ScrollViewer
            x:Name="MainScroll"
            beh:ScrollLoadBehavior.LoadMoreCommand="{Binding LoadNextPageCommand}"
            beh:ScrollLoadBehavior.Threshold="120"
            VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="900" Margin="32,28,32,40">

                <!--  Header  -->
                <TextBlock
                    Margin="0,0,0,6"
                    FontSize="22"
                    FontWeight="Bold"
                    Foreground="{DynamicResource Text1}"
                    Text="Actualités" />
                <TextBlock
                    Margin="0,0,0,24"
                    FontSize="12"
                    Foreground="{DynamicResource Text3}"
                    Text="{Binding TotalCount, StringFormat='{}{0} article(s) publié(s)'}" />

                <!--  Initial loading  -->
                <StackPanel
                    Margin="0,60,0,0"
                    HorizontalAlignment="Center"
                    Visibility="{Binding IsInitialLoading, Converter={StaticResource BoolToVis}}">
                    <ui:ProgressRing
                        Width="32"
                        Height="32"
                        Foreground="{DynamicResource AccentSoft}" />
                </StackPanel>

                <!--  Articles list  -->
                <ItemsControl ItemsSource="{Binding Articles}" Visibility="{Binding IsInitialLoading, Converter={StaticResource BoolToVisNot}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type viewModels:NewsArticleViewModel}">
                            <Border
                                Margin="0,0,0,14"
                                Background="{DynamicResource Surface1}"
                                BorderBrush="{DynamicResource Border1}"
                                BorderThickness="1"
                                Cursor="Hand">
                                <Border.InputBindings>
                                    <MouseBinding
                                        Command="{Binding DataContext.OpenArticleCommand, ElementName=ThisControl}"
                                        CommandParameter="{Binding}"
                                        MouseAction="LeftClick" />
                                </Border.InputBindings>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border
                                        Grid.Column="0"
                                        Height="130"
                                        ClipToBounds="True">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Offset="0" Color="{DynamicResource C_HeroBgStart}" />
                                                <GradientStop Offset="1" Color="{DynamicResource C_HeroBgMid}" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <Image
                                        Grid.Column="0"
                                        Height="130"
                                        beh:AsyncImageBehavior.Source="{Binding ImageUrl}"
                                        Stretch="UniformToFill"
                                        Visibility="{Binding HasHeroImage, Converter={StaticResource BoolToVis}}" />

                                    <StackPanel
                                        Grid.Column="1"
                                        Margin="18,14,18,14"
                                        VerticalAlignment="Center">
                                        <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                                            <Border
                                                Margin="0,0,10,0"
                                                Padding="8,2"
                                                Background="{DynamicResource AccentSelectedBg}">
                                                <TextBlock
                                                    FontSize="10"
                                                    FontWeight="Bold"
                                                    Foreground="{DynamicResource AccentSoft}"
                                                    Text="{Binding Category}" />
                                            </Border>
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="11"
                                                Foreground="{DynamicResource Text3}"
                                                Text="{Binding PublishedAt, StringFormat='{}{0:dd MMM yyyy}'}" />
                                        </StackPanel>
                                        <TextBlock
                                            Margin="0,0,0,6"
                                            FontSize="15"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource Text1}"
                                            Text="{Binding Title}"
                                            TextWrapping="Wrap" />
                                        <TextBlock
                                            MaxHeight="40"
                                            FontSize="12"
                                            Foreground="{DynamicResource Text3}"
                                            Text="{Binding ExcerptText}"
                                            TextTrimming="CharacterEllipsis"
                                            TextWrapping="Wrap" />
                                        <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                                            <ui:FontIcon
                                                Margin="0,0,4,0"
                                                FontSize="12"
                                                Foreground="{DynamicResource Text3}"
                                                Glyph="&#xE8E1;" />
                                            <TextBlock
                                                Margin="0,0,14,0"
                                                VerticalAlignment="Center"
                                                FontSize="11"
                                                Foreground="{DynamicResource Text3}"
                                                Text="{Binding LikeCount}" />
                                            <ui:FontIcon
                                                Margin="0,0,4,0"
                                                FontSize="12"
                                                Foreground="{DynamicResource Text3}"
                                                Glyph="&#xE8BD;" />
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="11"
                                                Foreground="{DynamicResource Text3}"
                                                Text="{Binding CommentCount}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!--  Spinner chargement suivant  -->
                <StackPanel
                    Margin="0,12,0,0"
                    HorizontalAlignment="Center"
                    Visibility="{Binding IsLoadingMore, Converter={StaticResource BoolToVis}}">
                    <ui:ProgressRing
                        Width="24"
                        Height="24"
                        Foreground="{DynamicResource AccentSoft}" />
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>