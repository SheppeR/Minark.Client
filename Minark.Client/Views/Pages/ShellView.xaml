<UserControl
    x:Class="Minark.Client.Views.Pages.ShellView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:beh="clr-namespace:Minark.Client.Behaviors"
    xmlns:packets="clr-namespace:Minark.Shared.Packets;assembly=Minark.Shared"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  ══ SIDEBAR ══════════════════════════════════════════════════════  -->
        <Border
            Grid.Column="0"
            BorderBrush="{DynamicResource Border1}"
            BorderThickness="0,0,1,0">
            <Border.Background>
                <SolidColorBrush Color="{DynamicResource C_Surface0}" />
            </Border.Background>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  Logo  -->
                <Border Grid.Row="0" Padding="22,22,22,0">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,16"
                            FontSize="21"
                            FontWeight="Bold">
                            <Span Foreground="{DynamicResource Text1}">min</Span>
                            <Span Foreground="{DynamicResource AccentSoft}">ark</Span>
                        </TextBlock>
                        <Border Height="1" Margin="0,0,40,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Offset="0" Color="{DynamicResource C_Accent1}" />
                                    <GradientStop Offset="1" Color="Transparent" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </StackPanel>
                </Border>

                <!--  Nav items  -->
                <StackPanel Grid.Row="1" Margin="10,12,10,0">

                    <!--  Dashboard  -->
                    <Button
                        HorizontalContentAlignment="Stretch"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="Dashboard"
                        Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border
                                    x:Name="bg"
                                    Margin="0,2"
                                    Padding="12,10"
                                    CornerRadius="0">
                                    <StackPanel Orientation="Horizontal">
                                        <Border
                                            x:Name="iconWrap"
                                            Width="30"
                                            Height="30"
                                            Margin="0,0,12,0"
                                            Background="{DynamicResource Surface3}"
                                            CornerRadius="0">
                                            <ui:FontIcon
                                                FontSize="14"
                                                Foreground="{DynamicResource Text2}"
                                                Glyph="&#xE80F;" />
                                        </Border>
                                        <TextBlock
                                            x:Name="lbl"
                                            VerticalAlignment="Center"
                                            FontSize="13.5"
                                            FontWeight="Medium"
                                            Foreground="{DynamicResource Text2}"
                                            Text="Dashboard" />
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding ActiveSection}" Value="Dashboard">
                                        <Setter TargetName="bg" Property="Background" Value="{DynamicResource AccentSelectedBg}" />
                                        <Setter TargetName="lbl" Property="Foreground" Value="White" />
                                        <Setter TargetName="lbl" Property="FontWeight" Value="SemiBold" />
                                        <Setter TargetName="iconWrap" Property="Background" Value="{DynamicResource AccentBorderHover}" />
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="{DynamicResource AccentHoverBg}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!--  Actualités  -->
                    <Button
                        HorizontalContentAlignment="Stretch"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="News"
                        Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border
                                    x:Name="bg"
                                    Margin="0,2"
                                    Padding="12,10"
                                    CornerRadius="0">
                                    <StackPanel Orientation="Horizontal">
                                        <Border
                                            x:Name="iconWrap"
                                            Width="30"
                                            Height="30"
                                            Margin="0,0,12,0"
                                            Background="{DynamicResource Surface3}"
                                            CornerRadius="0">
                                            <ui:FontIcon
                                                FontSize="14"
                                                Foreground="{DynamicResource Text2}"
                                                Glyph="&#xE900;" />
                                        </Border>
                                        <TextBlock
                                            x:Name="lbl"
                                            VerticalAlignment="Center"
                                            FontSize="13.5"
                                            FontWeight="Medium"
                                            Foreground="{DynamicResource Text2}"
                                            Text="Actualités" />
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding ActiveSection}" Value="News">
                                        <Setter TargetName="bg" Property="Background" Value="{DynamicResource AccentSelectedBg}" />
                                        <Setter TargetName="lbl" Property="Foreground" Value="White" />
                                        <Setter TargetName="lbl" Property="FontWeight" Value="SemiBold" />
                                        <Setter TargetName="iconWrap" Property="Background" Value="{DynamicResource AccentBorderHover}" />
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="{DynamicResource AccentHoverBg}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!--  Amis — ouvre la FriendsWindow via event dans ShellView.xaml.cs  -->
                    <Button
                        HorizontalContentAlignment="Stretch"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding OpenFriendsCommand}"
                        Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border
                                    x:Name="bg"
                                    Margin="0,2"
                                    Padding="12,10"
                                    CornerRadius="0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border
                                            x:Name="iconWrap"
                                            Width="30"
                                            Height="30"
                                            Margin="0,0,12,0"
                                            Background="{DynamicResource Surface3}"
                                            CornerRadius="0">
                                            <ui:FontIcon
                                                FontSize="14"
                                                Foreground="{DynamicResource Text2}"
                                                Glyph="&#xE716;" />
                                        </Border>
                                        <TextBlock
                                            x:Name="lbl"
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            FontSize="13.5"
                                            FontWeight="Medium"
                                            Foreground="{DynamicResource Text2}"
                                            Text="Amis" />
                                        <!--  Badge  -->
                                        <Border
                                            Grid.Column="2"
                                            Height="18"
                                            MinWidth="18"
                                            Margin="0,0,2,0"
                                            Padding="4,0"
                                            Visibility="{Binding HasBadge, Converter={StaticResource BoolToVis}}">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Offset="0" Color="{DynamicResource C_Accent1}" />
                                                    <GradientStop Offset="1" Color="{DynamicResource C_AccentDark}" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontSize="10"
                                                FontWeight="Bold"
                                                Foreground="White"
                                                Text="{Binding BadgeText}" />
                                        </Border>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="{DynamicResource AccentHoverBg}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!--  Bibliothèque  -->
                    <Button
                        HorizontalContentAlignment="Stretch"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="Library"
                        Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border
                                    x:Name="bg"
                                    Margin="0,2"
                                    Padding="12,10"
                                    CornerRadius="0">
                                    <StackPanel Orientation="Horizontal">
                                        <Border
                                            x:Name="iconWrap"
                                            Width="30"
                                            Height="30"
                                            Margin="0,0,12,0"
                                            Background="{DynamicResource Surface3}"
                                            CornerRadius="0">
                                            <ui:FontIcon
                                                FontSize="14"
                                                Foreground="{DynamicResource Text2}"
                                                Glyph="&#xE7FC;" />
                                        </Border>
                                        <TextBlock
                                            x:Name="lbl"
                                            VerticalAlignment="Center"
                                            FontSize="13.5"
                                            FontWeight="Medium"
                                            Foreground="{DynamicResource Text2}"
                                            Text="Bibliothèque" />
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding ActiveSection}" Value="Library">
                                        <Setter TargetName="bg" Property="Background" Value="{DynamicResource AccentSelectedBg}" />
                                        <Setter TargetName="lbl" Property="Foreground" Value="White" />
                                        <Setter TargetName="lbl" Property="FontWeight" Value="SemiBold" />
                                        <Setter TargetName="iconWrap" Property="Background" Value="{DynamicResource AccentBorderHover}" />
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="{DynamicResource AccentHoverBg}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!--  Paramètres  -->
                    <Button
                        HorizontalContentAlignment="Stretch"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="Settings"
                        Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border
                                    x:Name="bg"
                                    Margin="0,2"
                                    Padding="12,10"
                                    CornerRadius="0">
                                    <StackPanel Orientation="Horizontal">
                                        <Border
                                            x:Name="iconWrap"
                                            Width="30"
                                            Height="30"
                                            Margin="0,0,12,0"
                                            Background="{DynamicResource Surface3}"
                                            CornerRadius="0">
                                            <ui:FontIcon
                                                FontSize="14"
                                                Foreground="{DynamicResource Text2}"
                                                Glyph="&#xE713;" />
                                        </Border>
                                        <TextBlock
                                            x:Name="lbl"
                                            VerticalAlignment="Center"
                                            FontSize="13.5"
                                            FontWeight="Medium"
                                            Foreground="{DynamicResource Text2}"
                                            Text="Paramètres" />
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding ActiveSection}" Value="Settings">
                                        <Setter TargetName="bg" Property="Background" Value="{DynamicResource AccentSelectedBg}" />
                                        <Setter TargetName="lbl" Property="Foreground" Value="White" />
                                        <Setter TargetName="lbl" Property="FontWeight" Value="SemiBold" />
                                        <Setter TargetName="iconWrap" Property="Background" Value="{DynamicResource AccentBorderHover}" />
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="{DynamicResource AccentHoverBg}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>

                <!--  ── User card (bas gauche) ──────────────────────────────  -->
                <Border
                    Grid.Row="2"
                    Margin="10,0,10,0"
                    Padding="4,12,4,8"
                    BorderBrush="{DynamicResource Border1}"
                    BorderThickness="0,1,0,0">
                    <Button
                        HorizontalContentAlignment="Stretch"
                        beh:ContextMenuButtonBehavior.OpenOnClick="True"
                        beh:ContextMenuButtonBehavior.Placement="Top"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem
                                    Command="{Binding ChangeStatusCommand}"
                                    CommandParameter="{x:Static packets:UserStatus.Online}"
                                    Header="En ligne">
                                    <MenuItem.Icon>
                                        <Ellipse
                                            Width="10"
                                            Height="10"
                                            Fill="{DynamicResource StatusOnline}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem
                                    Command="{Binding ChangeStatusCommand}"
                                    CommandParameter="{x:Static packets:UserStatus.Busy}"
                                    Header="Occupé">
                                    <MenuItem.Icon>
                                        <Ellipse
                                            Width="10"
                                            Height="10"
                                            Fill="{DynamicResource StatusBusy}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem
                                    Command="{Binding ChangeStatusCommand}"
                                    CommandParameter="{x:Static packets:UserStatus.Away}"
                                    Header="Absent">
                                    <MenuItem.Icon>
                                        <Ellipse
                                            Width="10"
                                            Height="10"
                                            Fill="{DynamicResource StatusAway}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem
                                    Command="{Binding ChangeStatusCommand}"
                                    CommandParameter="{x:Static packets:UserStatus.Offline}"
                                    Header="Invisible">
                                    <MenuItem.Icon>
                                        <Ellipse
                                            Width="10"
                                            Height="10"
                                            Fill="{DynamicResource StatusOffline}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </Button.ContextMenu>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border
                                    x:Name="bg"
                                    Padding="10,8"
                                    CornerRadius="0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!--  Avatar  -->
                                        <Grid
                                            Grid.Column="0"
                                            Width="36"
                                            Height="36"
                                            Margin="0,0,10,0">
                                            <Border
                                                Width="36"
                                                Height="36"
                                                CornerRadius="0"
                                                Visibility="{Binding AvatarUrl, Converter={StaticResource StringToVis}, ConverterParameter=inverse}">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Offset="0" Color="{DynamicResource C_Accent1}" />
                                                        <GradientStop Offset="1" Color="{DynamicResource C_Accent2}" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontSize="13"
                                                    FontWeight="Bold"
                                                    Foreground="{DynamicResource OnAccentText}"
                                                    Text="{Binding Initials}" />
                                            </Border>
                                            <Border
                                                Width="36"
                                                Height="36"
                                                CornerRadius="0"
                                                Visibility="{Binding AvatarUrl, Converter={StaticResource StringToVis}}">
                                                <Border.Background>
                                                    <ImageBrush ImageSource="{Binding AvatarUrl, Converter={StaticResource UrlToImage}}" Stretch="UniformToFill" />
                                                </Border.Background>
                                            </Border>
                                            <Ellipse
                                                Width="11"
                                                Height="11"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Bottom"
                                                Stroke="{DynamicResource Surface0}"
                                                StrokeThickness="2">
                                                <Ellipse.Fill>
                                                    <SolidColorBrush Color="{Binding CurrentStatus, Converter={StaticResource StatusToColor}}" />
                                                </Ellipse.Fill>
                                            </Ellipse>
                                        </Grid>

                                        <!--  Username + status  -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock
                                                FontSize="13"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource Text1}"
                                                Text="{Binding Username}"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                FontSize="11"
                                                Foreground="{Binding CurrentStatus, Converter={StaticResource StatusToBrush}}"
                                                Text="{Binding StatusText}" />
                                        </StackPanel>

                                        <ui:FontIcon
                                            Grid.Column="2"
                                            Margin="6,0,0,0"
                                            VerticalAlignment="Center"
                                            FontSize="9"
                                            Foreground="{DynamicResource Text3}"
                                            Glyph="&#xE70D;" />
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="{DynamicResource HoverRowBg}" />
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="{DynamicResource AccentHoverBg}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Border>

                <!--  ── Téléchargements ─────────────────────────────────────  -->
                <Border Grid.Row="3" Padding="10,0,10,16">
                    <Button
                        Padding="0"
                        HorizontalContentAlignment="Stretch"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="Downloads"
                        Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border
                                    x:Name="bg"
                                    Padding="12,9"
                                    CornerRadius="0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!--  Icône avec badge superposé  -->
                                        <Grid
                                            Grid.Column="0"
                                            Width="30"
                                            Height="30"
                                            Margin="0,0,12,0">
                                            <Border
                                                Width="30"
                                                Height="30"
                                                Background="{DynamicResource Surface3}"
                                                CornerRadius="0">
                                                <ui:FontIcon
                                                    FontSize="14"
                                                    Foreground="{DynamicResource Text3}"
                                                    Glyph="&#xE896;" />
                                            </Border>
                                            <!--  Badge point rouge update  -->
                                            <Ellipse
                                                Width="9"
                                                Height="9"
                                                Margin="0,-2,-2,0"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Visibility="{Binding HasUpdateBadge, Converter={StaticResource BoolToVis}}">
                                                <Ellipse.Fill>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Offset="0" Color="{DynamicResource C_Accent1}" />
                                                        <GradientStop Offset="1" Color="{DynamicResource C_Accent2}" />
                                                    </LinearGradientBrush>
                                                </Ellipse.Fill>
                                            </Ellipse>
                                        </Grid>

                                        <TextBlock
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            FontSize="13"
                                            Foreground="{DynamicResource Text3}"
                                            Text="Téléchargements" />

                                        <!--  Badge "MAJ" texte  -->
                                        <Border
                                            Grid.Column="2"
                                            Margin="4,0,0,0"
                                            Padding="5,2"
                                            VerticalAlignment="Center"
                                            CornerRadius="4"
                                            Visibility="{Binding HasUpdateBadge, Converter={StaticResource BoolToVis}}">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Offset="0" Color="{DynamicResource C_Accent1}" />
                                                    <GradientStop Offset="1" Color="{DynamicResource C_Accent2}" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontSize="9"
                                                FontWeight="Bold"
                                                Foreground="White"
                                                Text="MAJ" />
                                        </Border>

                                        <ui:FontIcon
                                            Grid.Column="3"
                                            Margin="6,0,0,0"
                                            VerticalAlignment="Center"
                                            FontSize="9"
                                            Foreground="{DynamicResource Text3}"
                                            Glyph="&#xE70D;" />
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="{DynamicResource AccentHoverBg}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Border>

            </Grid>
        </Border>

        <!--  ══ CONTENT ══════════════════════════════════════════════════════  -->
        <Frame
            x:Name="NavFrame"
            Grid.Column="1"
            Padding="0,50,5,0"
            Background="{DynamicResource Surface0}"
            NavigationUIVisibility="Hidden" />

    </Grid>
</UserControl>