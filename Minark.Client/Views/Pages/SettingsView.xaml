<UserControl x:Class="Minark.Client.Views.Pages.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:beh="clr-namespace:Minark.Client.Behaviors"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
             xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf">

    <Grid>
        <Grid.Background>
            <SolidColorBrush Color="{DynamicResource C_Surface0}" />
        </Grid.Background>

        <Grid Margin="32,28,32,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Margin="0,0,0,6"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="{DynamicResource Text1}"
                       Text="Paramètres" />

            <TabControl Grid.Row="1" Style="{StaticResource PivotTabControl}">

                <!-- ══════════════════════════════════════════════════════════════════
                 APPARENCE
                 ══════════════════════════════════════════════════════════════════ -->
                <TabItem Style="{StaticResource PivotTabItem}">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Color}"
                                         FontSize="14" Margin="0,0,8,0" />
                            <TextBlock Text="Apparence" VerticalAlignment="Center" />
                        </StackPanel>
                    </TabItem.Header>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,16,16,16">
                        <ikw:SimpleStackPanel Spacing="8">

                            <ui:SettingsCard Header="Thème de l'interface"
                                             Description="Basculer entre le mode sombre et le mode clair">
                                <ui:SettingsCard.HeaderIcon>
                                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Color}" />
                                </ui:SettingsCard.HeaderIcon>
                                <ui:ToggleSwitch IsOn="{Binding IsLight, Mode=TwoWay}"
                                                 OnContent="Clair" OffContent="Sombre" />
                            </ui:SettingsCard>

                            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="0" Padding="16,14">
                                <StackPanel>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <ui:FontIcon Grid.Column="0"
                                                     Icon="{x:Static ui:SegoeFluentIcons.Color}"
                                                     FontSize="20" Margin="0,0,16,0" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Couleur d'accentuation"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                            <TextBlock Text="Choisissez la couleur principale de l'interface"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding AccentColors}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="40" Height="40" Margin="4" CornerRadius="6"
                                                        Cursor="Hand"
                                                        Background="{Binding}">
                                                    <Border.InputBindings>
                                                        <MouseBinding MouseAction="LeftClick"
                                                                      Command="{Binding DataContext.ApplyAccentColorCommand,
                                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                      CommandParameter="{Binding}" />
                                                    </Border.InputBindings>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                        </ikw:SimpleStackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ══════════════════════════════════════════════════════════════════
                 SONS
                 ══════════════════════════════════════════════════════════════════ -->
                <TabItem Style="{StaticResource PivotTabItem}">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <ui:FontIcon Glyph="&#xE767;" FontSize="14" Margin="0,0,8,0" />
                            <TextBlock Text="Notifications" VerticalAlignment="Center" />
                        </StackPanel>
                    </TabItem.Header>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,16,16,16">
                        <ikw:SimpleStackPanel Spacing="8">

                            <ui:SettingsCard Header="Sons de notification"
                                             Description="Jouer un son lors de la réception d'un message">
                                <ui:SettingsCard.HeaderIcon>
                                    <ui:FontIcon Glyph="&#xE767;" />
                                </ui:SettingsCard.HeaderIcon>
                                <ui:ToggleSwitch IsOn="{Binding SoundEnabled, Mode=TwoWay}"
                                                 OnContent="Activés" OffContent="Désactivés" />
                            </ui:SettingsCard>

                            <ui:SettingsCard Header="Notifications visuelles"
                                             Description="Afficher une notification toast lors d'un nouveau message">
                                <ui:SettingsCard.HeaderIcon>
                                    <ui:FontIcon Glyph="&#xEA8F;" />
                                </ui:SettingsCard.HeaderIcon>
                                <ui:ToggleSwitch IsOn="{Binding ToastEnabled, Mode=TwoWay}"
                                                 OnContent="Activées" OffContent="Désactivées" />
                            </ui:SettingsCard>

                        </ikw:SimpleStackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ══════════════════════════════════════════════════════════════════
                 PROFIL
                 ══════════════════════════════════════════════════════════════════ -->
                <TabItem Style="{StaticResource PivotTabItem}">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <ui:FontIcon Glyph="&#xE77B;" FontSize="14" Margin="0,0,8,0" />
                            <TextBlock Text="Profil" VerticalAlignment="Center" />
                        </StackPanel>
                    </TabItem.Header>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,16,16,16">
                        <ikw:SimpleStackPanel Spacing="8">

                            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="0" Padding="16,14">
                                <StackPanel>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <ui:FontIcon Grid.Column="0" Glyph="&#xE77B;"
                                                     FontSize="20" Margin="0,0,16,0" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Photo de profil"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                            <TextBlock Text="URL d'une image (HTTPS recommandé)"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                    </Grid>

                                    <ui:InfoBar Title="{Binding AvatarMessage}"
                                                Severity="Success" IsClosable="False"
                                                IsOpen="{Binding AvatarSuccess}"
                                                Margin="0,0,0,10" />
                                    <ui:InfoBar Title="{Binding AvatarMessage}"
                                                Severity="Error" IsClosable="False"
                                                IsOpen="{Binding AvatarError}"
                                                Margin="0,0,0,10" />

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="AvatarPathBox"
                                                 Text="{Binding AvatarFileName}"
                                                 ui:ControlHelper.PlaceholderText="Aucun fichier sélectionné"
                                                 IsReadOnly="True"
                                                 Margin="0,0,8,0"
                                                 IsEnabled="{Binding AvatarNotLoading}" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Content="Parcourir…"
                                                    Command="{Binding BrowseAvatarCommand}"
                                                    IsEnabled="{Binding AvatarNotLoading}"
                                                    Margin="0,0,8,0"
                                                    Padding="14,6" />
                                            <Button Content="Envoyer"
                                                    Style="{StaticResource AccentButtonStyle}"
                                                    x:Name="UploadAvatarBtn"
                                                    IsEnabled="{Binding AvatarNotLoading}"
                                                    Padding="14,6"
                                                    Command="{Binding UploadSelectedAvatarCommand}" />
                                        </StackPanel>
                                    </Grid>
                                    <ProgressBar IsIndeterminate="True" Height="2" Margin="0,8,0,0"
                                                 Visibility="{Binding AvatarLoading, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>
                            </Border>

                        </ikw:SimpleStackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ══════════════════════════════════════════════════════════════════
                 SÉCURITÉ
                 ══════════════════════════════════════════════════════════════════ -->
                <TabItem Style="{StaticResource PivotTabItem}">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <ui:FontIcon Glyph="&#xE72E;" FontSize="14" Margin="0,0,8,0" />
                            <TextBlock Text="Sécurité" VerticalAlignment="Center" />
                        </StackPanel>
                    </TabItem.Header>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,16,16,16">
                        <ikw:SimpleStackPanel Spacing="8">

                            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="0" Padding="16,14">
                                <StackPanel>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <ui:FontIcon Grid.Column="0" Glyph="&#xE72E;"
                                                     FontSize="20" Margin="0,0,16,0" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Changer le mot de passe"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                            <TextBlock Text="Minimum 6 caractères"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                    </Grid>

                                    <ui:InfoBar Title="{Binding PwdMessage}"
                                                Severity="Success" IsClosable="False"
                                                IsOpen="{Binding PwdSuccess}"
                                                Margin="0,0,0,10" />
                                    <ui:InfoBar Title="{Binding PwdMessage}"
                                                Severity="Error" IsClosable="False"
                                                IsOpen="{Binding PwdError}"
                                                Margin="0,0,0,10" />

                                    <TextBlock Text="Mot de passe actuel"
                                               Style="{StaticResource FieldLabel}"
                                               Margin="0,0,0,6" />
                                    <PasswordBox x:Name="OldPwdBox" Margin="0,0,0,12"
                                                 beh:PasswordBoxBehavior.BoundPassword="{Binding OldPassword, Mode=TwoWay}"
                                                 IsEnabled="{Binding PwdNotLoading}" />

                                    <TextBlock Text="Nouveau mot de passe"
                                               Style="{StaticResource FieldLabel}"
                                               Margin="0,0,0,6" />
                                    <PasswordBox x:Name="NewPwdBox" Margin="0,0,0,12"
                                                 beh:PasswordBoxBehavior.BoundPassword="{Binding NewPassword, Mode=TwoWay}"
                                                 IsEnabled="{Binding PwdNotLoading}" />

                                    <TextBlock Text="Confirmer le mot de passe"
                                               Style="{StaticResource FieldLabel}"
                                               Margin="0,0,0,6" />
                                    <PasswordBox x:Name="ConfirmPwdBox" Margin="0,0,0,14"
                                                 beh:PasswordBoxBehavior.BoundPassword="{Binding ConfirmPassword, Mode=TwoWay}"
                                                 IsEnabled="{Binding PwdNotLoading}" />

                                    <ProgressBar IsIndeterminate="True" Height="2" Margin="0,0,0,8"
                                                 Visibility="{Binding PwdLoading, Converter={StaticResource BoolToVis}}" />

                                    <Button Content="Modifier le mot de passe"
                                            Style="{StaticResource AccentButtonStyle}"
                                            Command="{Binding ChangePasswordCommand}"
                                            IsEnabled="{Binding PwdNotLoading}"
                                            HorizontalAlignment="Left"
                                            Padding="16,8" />
                                </StackPanel>
                            </Border>

                        </ikw:SimpleStackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ══════════════════════════════════════════════════════════════════
                 JEU
                 ══════════════════════════════════════════════════════════════════ -->
                <TabItem Style="{StaticResource PivotTabItem}">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Game}"
                                         FontSize="14" Margin="0,0,8,0" />
                            <TextBlock Text="Jeu" VerticalAlignment="Center" />
                        </StackPanel>
                    </TabItem.Header>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,16,16,16">
                        <ikw:SimpleStackPanel Spacing="8">

                            <ui:SettingsCard Header="Dossier d'installation"
                                             Description="Dossier où le jeu est installé et téléchargé">
                                <ui:SettingsCard.HeaderIcon>
                                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.FolderOpen}" />
                                </ui:SettingsCard.HeaderIcon>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding GameInstallPath}"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               Foreground="{DynamicResource Text2}"
                                               MaxWidth="300"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,0,12,0" />
                                    <Button Command="{Binding ChooseInstallFolderCommand}"
                                            Content="Parcourir…"
                                            Padding="12,6" />
                                </StackPanel>
                            </ui:SettingsCard>

                        </ikw:SimpleStackPanel>
                    </ScrollViewer>
                </TabItem>

            </TabControl>
        </Grid>
    </Grid>
</UserControl>