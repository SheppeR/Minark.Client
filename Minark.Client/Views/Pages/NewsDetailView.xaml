<UserControl
    x:Class="Minark.Client.Views.Pages.NewsDetailView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:beh="clr-namespace:Minark.Client.Behaviors"
    xmlns:controls="clr-namespace:Minark.Client.Controls"
    xmlns:h="clr-namespace:Minark.Client.Helpers"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern">
    <UserControl.Resources>
        <ResourceDictionary>
            <DataTemplate x:Key="TextBlockTemplate">
                <TextBlock
                    Margin="0,0,0,12"
                    h:InlinesBinder.Inlines="{Binding Inlines}"
                    FontSize="14"
                    Foreground="{DynamicResource Text1}"
                    LineHeight="24"
                    TextWrapping="Wrap" />
            </DataTemplate>
            <DataTemplate x:Key="ImageBlockTemplate">
                <Border
                    MaxHeight="420"
                    Margin="0,8,0,16"
                    ClipToBounds="True"
                    CornerRadius="0">
                    <Image beh:AsyncImageBehavior.Source="{Binding Value}" Stretch="UniformToFill" />
                </Border>
            </DataTemplate>
            <h:ContentBlockTemplateSelector
                x:Key="BlockSelector"
                ImageTemplate="{StaticResource ImageBlockTemplate}"
                TextTemplate="{StaticResource TextBlockTemplate}" />
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.Background>
            <SolidColorBrush Color="{DynamicResource C_Surface0}" />
        </Grid.Background>

        <ScrollViewer
            x:Name="MainScroll"
            beh:ScrollLoadBehavior.LoadMoreCommand="{Binding LoadMoreCommentsCommand}"
            beh:ScrollLoadBehavior.Threshold="80"
            VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="860" Margin="40,24,40,40">

                <!--  Back button  -->
                <Button
                    x:Name="BackBtn"
                    Margin="0,0,0,20"
                    HorizontalAlignment="Left"
                    Background="Transparent"
                    BorderThickness="0"
                    Command="NavigationCommands.BrowseBack"
                    Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon
                            Margin="0,0,8,0"
                            FontSize="12"
                            Foreground="{DynamicResource AccentSoft}"
                            Glyph="&#xE72B;" />
                        <TextBlock
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AccentSoft}"
                            Text="Retour" />
                    </StackPanel>
                </Button>

                <!--  Category + date  -->
                <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                    <Border
                        Margin="0,0,12,0"
                        Padding="10,3"
                        Background="{DynamicResource AccentSelectedBg}"
                        CornerRadius="0">
                        <TextBlock
                            FontSize="11"
                            FontWeight="Bold"
                            Foreground="{DynamicResource AccentSoft}"
                            Text="{Binding Category}" />
                    </Border>
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{DynamicResource Text3}"
                        Text="{Binding PublishedAt, StringFormat='{}{0:dd MMMM yyyy}', Mode=OneWay}" />
                </StackPanel>

                <!--  Title  -->
                <TextBlock
                    Margin="0,0,0,20"
                    FontSize="26"
                    FontWeight="Bold"
                    Foreground="{DynamicResource Text1}"
                    Text="{Binding Title}"
                    TextWrapping="Wrap" />

                <!--  Carousel images  -->
                <Border
                    MaxHeight="420"
                    Margin="0,0,0,28"
                    ClipToBounds="True"
                    CornerRadius="0"
                    Visibility="{Binding HasCarousel, Converter={StaticResource BoolToVis}}">
                    <Grid>

                        <!--  Image courante  -->
                        <Image
                            MinHeight="280"
                            beh:AsyncImageBehavior.Source="{Binding CurrentCarouselImage}"
                            Stretch="UniformToFill" />

                        <!--  Bouton précédent  -->
                        <Button
                            Width="36"
                            Height="36"
                            Margin="10,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Command="{Binding CarouselPrevCommand}"
                            Style="{StaticResource IconBtn}"
                            Visibility="{Binding CanGoPrev, Converter={StaticResource BoolToVis}}">
                            <Border
                                Width="36"
                                Height="36"
                                Background="#99000000"
                                CornerRadius="18">
                                <ui:FontIcon
                                    FontSize="14"
                                    Foreground="White"
                                    Glyph="&#xE76B;" />
                            </Border>
                        </Button>

                        <!--  Bouton suivant  -->
                        <Button
                            Width="36"
                            Height="36"
                            Margin="10,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Command="{Binding CarouselNextCommand}"
                            Style="{StaticResource IconBtn}"
                            Visibility="{Binding CanGoNext, Converter={StaticResource BoolToVis}}">
                            <Border
                                Width="36"
                                Height="36"
                                Background="#99000000"
                                CornerRadius="18">
                                <ui:FontIcon
                                    FontSize="14"
                                    Foreground="White"
                                    Glyph="&#xE76C;" />
                            </Border>
                        </Button>

                        <!--  Indicateur position  -->
                        <Border
                            Margin="0,0,0,10"
                            Padding="8,3"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Background="#99000000"
                            CornerRadius="10">
                            <TextBlock
                                FontSize="11"
                                Foreground="White"
                                Text="{Binding CarouselPosition}" />
                        </Border>

                    </Grid>
                </Border>

                <!--  Hero image (fallback si pas de carousel)  -->
                <Image
                    MaxHeight="380"
                    Margin="0,0,0,28"
                    beh:AsyncImageBehavior.Source="{Binding ImageUrl}"
                    Stretch="UniformToFill"
                    Visibility="{Binding HasCarousel, Converter={StaticResource BoolToVisNot}}" />

                <!--  Content blocks  -->
                <ItemsControl ItemTemplateSelector="{StaticResource BlockSelector}"
                              ItemsSource="{Binding ContentBlocks}" />

                <!--  Reactions  -->
                <Border
                    Margin="0,24,0,0"
                    Padding="20,14"
                    Background="{DynamicResource Surface2}"
                    BorderBrush="{DynamicResource Border1}"
                    BorderThickness="1"
                    CornerRadius="0">
                    <StackPanel Orientation="Horizontal">
                        <Button
                            Margin="0,0,16,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Command="{Binding LikeCommand}"
                            Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon
                                    Margin="0,0,6,0"
                                    FontSize="16"
                                    Foreground="{DynamicResource AccentSoft}"
                                    Glyph="&#xE8E1;" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    Foreground="{DynamicResource Text2}"
                                    Text="{Binding LikeCount}" />
                            </StackPanel>
                        </Button>
                        <Button
                            Margin="0,0,24,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Command="{Binding DislikeCommand}"
                            Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon
                                    Margin="0,0,6,0"
                                    FontSize="16"
                                    Foreground="{DynamicResource Text2}"
                                    Glyph="&#xE8E0;" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    Foreground="{DynamicResource Text2}"
                                    Text="{Binding DislikeCount}" />
                            </StackPanel>
                        </Button>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="{DynamicResource Text3}">
                            <Run Text="{Binding CommentCount, Mode=OneWay}" />
                            <Run Text=" commentaire(s)" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!--  ══ COMMENTAIRES ═══════════════════════════════════════════  -->
                <StackPanel Margin="0,32,0,0">

                    <StackPanel Margin="0,0,0,16" Orientation="Horizontal">
                        <ui:FontIcon
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            FontSize="18"
                            Foreground="{DynamicResource AccentSoft}"
                            Glyph="&#xE8BD;" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="18"
                            FontWeight="Bold"
                            Foreground="{DynamicResource Text1}"
                            Text="Commentaires" />
                        <Border
                            Margin="10,0,0,0"
                            Padding="8,2"
                            VerticalAlignment="Center"
                            Background="{DynamicResource Surface3}"
                            CornerRadius="0">
                            <TextBlock
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource Text2}"
                                Text="{Binding CommentCount, Mode=OneWay}" />
                        </Border>
                    </StackPanel>

                    <controls:RichEditorControl
                        x:Name="CommentEditor"
                        Margin="0,0,0,16"
                        Html="{Binding NewCommentText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        MaxCharacters="2000"
                        Placeholder="Partagez votre avis sur cet article…">
                        <controls:RichEditorControl.ActionContent>
                            <Button
                                Height="30"
                                MinWidth="100"
                                Command="{Binding PostCommentCommand}"
                                Content="Publier"
                                FontSize="12"
                                Style="{StaticResource AccentBtn}" />
                        </controls:RichEditorControl.ActionContent>
                    </controls:RichEditorControl>

                    <Border
                        Margin="0,0,0,12"
                        Padding="28,32"
                        Background="{DynamicResource Surface2}"
                        BorderBrush="{DynamicResource Border1}"
                        BorderThickness="1"
                        CornerRadius="0"
                        Visibility="{Binding HasTopComments, Converter={StaticResource BoolToVisNot}}">
                        <StackPanel HorizontalAlignment="Center">
                            <ui:FontIcon
                                Margin="0,0,0,8"
                                HorizontalAlignment="Center"
                                FontSize="32"
                                Foreground="{DynamicResource Text3}"
                                Glyph="&#xE8BD;" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource Text2}"
                                Text="Aucun commentaire pour le moment" />
                            <TextBlock
                                Margin="0,4,0,0"
                                HorizontalAlignment="Center"
                                FontSize="12"
                                Foreground="{DynamicResource Text3}"
                                Text="Soyez le premier à partager votre avis !" />
                        </StackPanel>
                    </Border>

                    <ItemsControl ItemsSource="{Binding Comments}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Margin="0,0,0,10"
                                    Padding="16,14"
                                    Background="{DynamicResource Surface2}"
                                    BorderBrush="{DynamicResource Border1}"
                                    BorderThickness="1"
                                    CornerRadius="0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Grid
                                            Grid.Column="0"
                                            Width="36"
                                            Height="36"
                                            Margin="0,0,12,0"
                                            VerticalAlignment="Top">
                                            <Border
                                                Width="36"
                                                Height="36"
                                                CornerRadius="0"
                                                Visibility="{Binding AvatarUrl, Converter={StaticResource StringToVis}, ConverterParameter=inverse}">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Offset="0" Color="{DynamicResource C_Accent1}" />
                                                        <GradientStop Offset="1" Color="{DynamicResource C_Accent2}" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontSize="13"
                                                    FontWeight="Bold"
                                                    Foreground="{DynamicResource OnAccentText}"
                                                    Text="{Binding Username, Converter={StaticResource StringToInitials}}" />
                                            </Border>
                                            <Border
                                                Width="36"
                                                Height="36"
                                                CornerRadius="0"
                                                Visibility="{Binding AvatarUrl, Converter={StaticResource StringToVis}}">
                                                <Border.Background>
                                                    <ImageBrush
                                                        ImageSource="{Binding AvatarUrl, Converter={StaticResource UrlToImage}}"
                                                        Stretch="UniformToFill" />
                                                </Border.Background>
                                            </Border>
                                        </Grid>

                                        <StackPanel Grid.Column="1">
                                            <StackPanel Margin="0,0,0,6" Orientation="Horizontal">
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontSize="13"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource Text1}"
                                                    Text="{Binding Username}" />
                                                <Ellipse
                                                    Width="3"
                                                    Height="3"
                                                    Margin="8,0"
                                                    VerticalAlignment="Center"
                                                    Fill="{DynamicResource Text3}" />
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontSize="11"
                                                    Foreground="{DynamicResource Text3}"
                                                    Text="{Binding PostedAt, StringFormat='{}{0:dd MMM yyyy à HH:mm}'}" />
                                            </StackPanel>

                                            <ItemsControl
                                                ItemsSource="{Binding Content, Converter={StaticResource ContentToBlocks}}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock
                                                            Margin="0,0,0,4"
                                                            h:InlinesBinder.Inlines="{Binding Inlines}"
                                                            FontSize="13"
                                                            Foreground="{DynamicResource Text1}"
                                                            LineHeight="20"
                                                            TextWrapping="Wrap" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>