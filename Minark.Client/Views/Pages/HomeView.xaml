<UserControl
    x:Class="Minark.Client.Views.Pages.HomeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:beh="clr-namespace:Minark.Client.Behaviors"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    x:Name="ThisControl">

    <!--  Root: background image + overlay  -->
    <Grid>
        <!--  Subtle bg texture via gradient  -->
        <Border Background="{DynamicResource Surface0}" />
        <!--  Ambient purple glow top-right  -->
        <Border
            Width="500"
            Height="400"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            IsHitTestVisible="False">
            <Border.Background>
                <RadialGradientBrush Center="0.8,0.2" GradientOrigin="0.8,0.2" RadiusX="0.7" RadiusY="0.7">
                    <GradientStop Offset="0" Color="{DynamicResource C_Accent1_26}" />
                    <GradientStop Offset="1" Color="#00000000" />
                </RadialGradientBrush>
            </Border.Background>
        </Border>

        <ScrollViewer
            x:Name="MainScroll"
            beh:ScrollLoadBehavior.LoadMoreCommand="{Binding LoadNextPageCommand}"
            beh:ScrollLoadBehavior.Threshold="200"
            VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!--  ══ HEADER ══════════════════════════════════════════════  -->
                <StackPanel Margin="32,28,32,0">
                    <TextBlock
                        Margin="0,0,0,6"
                        FontSize="22"
                        FontWeight="Bold"
                        Foreground="{DynamicResource Text1}"
                        Text="Reprendre la partie" />
                    <TextBlock
                        Margin="0,0,0,24"
                        FontSize="12"
                        Foreground="{DynamicResource Text3}"
                        Text="Là où ton aventure s'est arrêtée" />
                </StackPanel>

                <!--  ══ HERO CARD ════════════════════════════════════════════  -->
                <Border
                    Height="250"
                    Margin="32,20,32,0"
                    ClipToBounds="True"
                    CornerRadius="0">
                    <Grid>
                        <!--  Base gradient  -->
                        <Border>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Offset="0" Color="{DynamicResource C_HeroBgStart}" />
                                    <GradientStop Offset="0.45" Color="{DynamicResource C_HeroBgMid}" />
                                    <GradientStop Offset="1" Color="{DynamicResource C_HeroBgStart}" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <!--  Purple nebula glow right side  -->
                        <Border
                            Width="400"
                            Height="400"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                            <Border.Background>
                                <RadialGradientBrush>
                                    <GradientStop Offset="0" Color="{DynamicResource C_Accent1_80}" />
                                    <GradientStop Offset="0.4" Color="{DynamicResource C_Accent2_40}" />
                                    <GradientStop Offset="1" Color="#00000000" />
                                </RadialGradientBrush>
                            </Border.Background>
                        </Border>
                        <!--  Pink glow top-right  -->
                        <Border
                            Width="250"
                            Height="250"
                            Margin="0,-50,-50,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top">
                            <Border.Background>
                                <RadialGradientBrush>
                                    <GradientStop Offset="0" Color="{DynamicResource C_Accent2_50}" />
                                    <GradientStop Offset="1" Color="#00000000" />
                                </RadialGradientBrush>
                            </Border.Background>
                        </Border>
                        <!--  Mountain silhouettes  -->
                        <Canvas
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            ClipToBounds="True">
                            <Path
                                Data="M 0,250 L 0,162 L 60,110 L 120,145 L 190,98 L 260,130 L 330,90 L 400,122 L 460,95 L 530,128 L 590,102 L 650,130 L 720,108 L 790,135 L 860,115 L 950,250 Z"
                                Fill="{DynamicResource MountainFarBrush}"
                                Opacity="0.95" />
                            <Path
                                Data="M 0,250 L 0,178 L 50,138 L 110,162 L 175,118 L 235,148 L 300,108 L 355,140 L 420,112 L 480,145 L 545,120 L 605,148 L 665,128 L 730,155 L 800,130 L 870,158 L 950,250 Z"
                                Fill="{DynamicResource MountainMidBrush}" />
                            <Path Data="M 0,250 L 0,192 L 60,168 L 100,178 L 130,162 L 160,250 Z"
                                  Fill="{DynamicResource MountainNearBrush}" />
                            <Path Data="M 950,250 L 950,188 L 900,165 L 862,176 L 830,158 L 800,250 Z"
                                  Fill="{DynamicResource MountainNearBrush}" />
                            <Ellipse
                                Canvas.Left="608"
                                Canvas.Top="60"
                                Width="8"
                                Height="8"
                                Fill="{DynamicResource AccentSoft}"
                                Opacity="0.9" />
                            <Ellipse
                                Canvas.Left="680"
                                Canvas.Top="88"
                                Width="6"
                                Height="6"
                                Fill="{DynamicResource AccentSecondary}"
                                Opacity="0.8" />
                            <Ellipse
                                Canvas.Left="550"
                                Canvas.Top="80"
                                Width="5"
                                Height="5"
                                Fill="{DynamicResource AccentSoft}"
                                Opacity="0.7" />
                            <Ellipse
                                Canvas.Left="730"
                                Canvas.Top="70"
                                Width="4"
                                Height="4"
                                Fill="{DynamicResource AccentSoft}"
                                Opacity="0.6" />
                        </Canvas>
                        <!--  Warrior silhouette  -->
                        <Path
                            Margin="0,0,220,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Data="M 50,200 L 34,124 L 42,124 L 42,50 L 62,50 L 62,124 L 70,124 L 54,200 Z M 34,124 L 14,84 L 24,80 L 42,124 Z M 62,124 L 82,84 L 90,88 L 70,124 Z M 42,50 L 36,10 L 62,10 L 56,50 Z M 56,50 L 72,30 L 90,52 Z"
                            Fill="{DynamicResource MountainSilhouetteBrush}" />
                        <!--  Left content overlay  -->
                        <Border>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Offset="0" Color="{DynamicResource C_HeroOverlayLeft0}" />
                                    <GradientStop Offset="0.32" Color="{DynamicResource C_HeroOverlayLeft1}" />
                                    <GradientStop Offset="0.52" Color="{DynamicResource C_HeroOverlayLeft2}" />
                                    <GradientStop Offset="0.82" Color="#00000000" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <!--  Content  -->
                        <StackPanel
                            MaxWidth="400"
                            Margin="28,0,0,22"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Bottom">
                            <TextBlock
                                Margin="0,0,0,5"
                                FontSize="32"
                                FontWeight="Black">
                                <Span Foreground="{DynamicResource OnAccentText}">min</Span>
                                <Span Foreground="{DynamicResource AccentSoft}">ark</Span>
                            </TextBlock>
                            <TextBlock
                                Margin="0,0,0,9"
                                FontSize="12.5"
                                Foreground="{DynamicResource OnAccentTextSoft}"
                                Text="Ton monde. Tes règles. Ton histoire." />
                            <StackPanel Margin="0,0,0,16" Orientation="Horizontal">
                                <ui:FontIcon
                                    Margin="0,0,6,0"
                                    VerticalAlignment="Center"
                                    FontSize="11"
                                    Foreground="{DynamicResource Text3}"
                                    Glyph="&#xE916;" />
                                <TextBlock FontSize="11" Foreground="{DynamicResource Text3}">
                                    <Run Text="Membres actifs" />
                                    <Run Text="  ·  " />
                                    <Run Text="Mis à jour Aujourd'hui" />
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Button
                                    Margin="0,0,10,0"
                                    BorderThickness="0"
                                    Command="{Binding LaunchGameCommand}"
                                    Cursor="Hand">
                                    <Button.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Offset="0" Color="{DynamicResource C_Accent1}" />
                                            <GradientStop Offset="1" Color="{DynamicResource C_AccentDark}" />
                                        </LinearGradientBrush>
                                    </Button.Background>
                                    <Button.Effect>
                                        <DropShadowEffect
                                            BlurRadius="16"
                                            Opacity="0.5"
                                            ShadowDepth="0"
                                            Color="{DynamicResource C_Accent1}" />
                                    </Button.Effect>
                                    <StackPanel Margin="18,9,18,9" Orientation="Horizontal">
                                        <ui:FontIcon
                                            Margin="0,0,8,0"
                                            VerticalAlignment="Center"
                                            FontSize="13"
                                            Foreground="{DynamicResource OnAccentText}"
                                            Glyph="&#xE768;" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource OnAccentText}"
                                            Text="{Binding LaunchGameLabel}" />
                                    </StackPanel>
                                </Button>
                                <Button
                                    Width="40"
                                    Height="38"
                                    Background="{DynamicResource OnAccentChip}"
                                    BorderBrush="{DynamicResource OnAccentChipBorder}"
                                    BorderThickness="1"
                                    Command="{Binding NavigateToSectionCommand}"
                                    CommandParameter="Settings"
                                    Cursor="Hand">
                                    <ui:FontIcon
                                        FontSize="15"
                                        Foreground="{DynamicResource OnAccentText}"
                                        Glyph="&#xE713;" />
                                </Button>
                            </StackPanel>
                        </StackPanel>
                        <!--  Progress dots  -->
                        <StackPanel
                            Margin="0,0,20,14"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Orientation="Horizontal">
                            <Border
                                Width="22"
                                Height="6"
                                Margin="0,0,5,0"
                                CornerRadius="0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Offset="0" Color="{DynamicResource C_Accent1}" />
                                        <GradientStop Offset="1" Color="{DynamicResource C_AccentSoft}" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <Border
                                Width="6"
                                Height="6"
                                Margin="0,0,5,0"
                                Background="{DynamicResource OnAccentChipStrong}"
                                CornerRadius="0" />
                            <Border
                                Width="6"
                                Height="6"
                                Margin="0,0,5,0"
                                Background="{DynamicResource OnAccentChipStrong}"
                                CornerRadius="0" />
                            <Border
                                Width="6"
                                Height="6"
                                Background="{DynamicResource OnAccentChipStrong}"
                                CornerRadius="0" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!--  ══ FRIEND ACTIVITY ══════════════════════════════════════  -->
                <Grid Margin="32,24,32,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock
                            FontSize="15"
                            FontWeight="Bold"
                            Foreground="{DynamicResource Text1}"
                            Text="Activité des amis" />
                        <TextBlock
                            Margin="0,2,0,0"
                            FontSize="11"
                            Foreground="{DynamicResource Text3}"
                            Text="Voir ce que tes amis font" />
                    </StackPanel>
                    <Button
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding OpenFriendsWindowCommand}"
                        Cursor="Hand">
                        <TextBlock
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AccentSoft}">
                            Voir tous les amis →
                        </TextBlock>
                    </Button>
                </Grid>

                <!--  Friends panel  -->
                <Border
                    Margin="32,12,32,0"
                    Padding="12,12"
                    Background="{DynamicResource Surface2}"
                    BorderBrush="{DynamicResource Border1}"
                    BorderThickness="1"
                    CornerRadius="0">
                    <Grid>
                        <TextBlock
                            Margin="0,16"
                            HorizontalAlignment="Center"
                            FontSize="12"
                            Foreground="{DynamicResource Text3}"
                            Text="Aucun ami en ligne pour le moment"
                            Visibility="{Binding HasOnlineFriends, Converter={StaticResource BoolToVisNot}}" />
                        <ScrollViewer
                            HorizontalScrollBarVisibility="Hidden"
                            VerticalScrollBarVisibility="Disabled"
                            Visibility="{Binding HasOnlineFriends, Converter={StaticResource BoolToVis}}">
                            <ItemsControl ItemsSource="{Binding OnlineFriends}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Width="155"
                                            Margin="0,0,10,0"
                                            Padding="12,12,12,12"
                                            Background="{DynamicResource Surface3}"
                                            CornerRadius="0"
                                            Cursor="Hand">
                                            <Border.BorderBrush>
                                                <SolidColorBrush
                                                    Color="{Binding Status, Converter={StaticResource StatusToColor}}" />
                                            </Border.BorderBrush>
                                            <Border.BorderThickness>0,2,0,0</Border.BorderThickness>
                                            <StackPanel>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid
                                                        Grid.Column="0"
                                                        Width="46"
                                                        Height="46"
                                                        HorizontalAlignment="Left">
                                                        <Border
                                                            Width="46"
                                                            Height="46"
                                                            CornerRadius="0"
                                                            Visibility="{Binding AvatarUrl, Converter={StaticResource StringToVis}, ConverterParameter=inverse}">
                                                            <Border.Background>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                    <GradientStop Offset="0"
                                                                            Color="{DynamicResource C_Accent1}" />
                                                                    <GradientStop Offset="1"
                                                                            Color="{DynamicResource C_AccentDark}" />
                                                                </LinearGradientBrush>
                                                            </Border.Background>
                                                            <TextBlock
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                FontSize="16"
                                                                FontWeight="Bold"
                                                                Foreground="{DynamicResource OnAccentText}"
                                                                Text="{Binding Initials}" />
                                                        </Border>
                                                        <Border
                                                            Width="46"
                                                            Height="46"
                                                            CornerRadius="0"
                                                            Visibility="{Binding AvatarUrl, Converter={StaticResource StringToVis}}">
                                                            <Border.Background>
                                                                <ImageBrush
                                                                    ImageSource="{Binding AvatarUrl, Converter={StaticResource UrlToImage}}"
                                                                    Stretch="UniformToFill" />
                                                            </Border.Background>
                                                        </Border>
                                                        <Ellipse
                                                            Width="13"
                                                            Height="13"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Bottom"
                                                            Stroke="{DynamicResource Surface3}"
                                                            StrokeThickness="2.5">
                                                            <Ellipse.Fill>
                                                                <SolidColorBrush
                                                                    Color="{Binding Status, Converter={StaticResource StatusToColor}}" />
                                                            </Ellipse.Fill>
                                                        </Ellipse>
                                                    </Grid>
                                                    <Button
                                                        Grid.Column="1"
                                                        Width="28"
                                                        Height="28"
                                                        VerticalAlignment="Top"
                                                        beh:ContextMenuButtonBehavior.OpenOnClick="True"
                                                        Style="{StaticResource IconBtn}"
                                                        Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        ToolTip="Gérer le contact">
                                                        <Button.ContextMenu>
                                                            <ContextMenu>
                                                                <MenuItem
                                                                    Command="{Binding PlacementTarget.Tag.OpenChatCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                    CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                    Header="Message" />
                                                                <Separator />
                                                                <MenuItem
                                                                    Command="{Binding PlacementTarget.Tag.BlockFriendCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                    CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                    Foreground="{DynamicResource Danger}"
                                                                    Header="Bloquer" />
                                                                <MenuItem
                                                                    Command="{Binding PlacementTarget.Tag.RemoveFriendCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                    CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                    Foreground="{DynamicResource Danger}"
                                                                    Header="Supprimer l'ami" />
                                                            </ContextMenu>
                                                        </Button.ContextMenu>
                                                        <ui:FontIcon
                                                            FontSize="12"
                                                            Foreground="{DynamicResource Text3}"
                                                            Glyph="&#xE713;" />
                                                    </Button>
                                                </Grid>
                                                <TextBlock
                                                    Margin="0,0,0,2"
                                                    FontSize="12"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource Text1}"
                                                    Text="{Binding Username}" />
                                                <TextBlock
                                                    Margin="0,0,0,8"
                                                    FontSize="10"
                                                    Foreground="{DynamicResource Text3}"
                                                    Text="Joue à minark" />
                                                <Border
                                                    Padding="8,4"
                                                    Background="{DynamicResource Surface4}"
                                                    BorderBrush="{DynamicResource Border1}"
                                                    BorderThickness="1"
                                                    CornerRadius="0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Ellipse
                                                            Width="6"
                                                            Height="6"
                                                            Margin="0,0,6,0"
                                                            VerticalAlignment="Center">
                                                            <Ellipse.Fill>
                                                                <SolidColorBrush
                                                                    Color="{Binding Status, Converter={StaticResource StatusToColor}}" />
                                                            </Ellipse.Fill>
                                                        </Ellipse>
                                                        <TextBlock
                                                            VerticalAlignment="Center"
                                                            FontSize="10"
                                                            Foreground="{Binding Status, Converter={StaticResource StatusToBrush}}"
                                                            Text="{Binding Status, Converter={StaticResource StatusToString}}" />
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!--  ══ ACTUALITÉS — CARDS ════════════════════════════════════  -->
                <Grid Margin="32,24,32,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock
                            FontSize="15"
                            FontWeight="Bold"
                            Foreground="{DynamicResource Text1}"
                            Text="Actualités" />
                        <TextBlock
                            Margin="0,2,0,0"
                            FontSize="11"
                            Foreground="{DynamicResource Text3}"
                            Text="Dernières nouvelles de la plateforme" />
                    </StackPanel>
                    <Button
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding NavigateToSectionCommand}"
                        CommandParameter="News"
                        Cursor="Hand">
                        <TextBlock
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AccentSoft}">
                            Voir tout →
                        </TextBlock>
                    </Button>
                </Grid>

                <!--  Loading  -->
                <StackPanel Margin="32,12,32,0"
                            Visibility="{Binding IsInitialLoading, Converter={StaticResource BoolToVis}}">
                    <ui:ProgressRing
                        Width="28"
                        Height="28"
                        Margin="0,20"
                        HorizontalAlignment="Center"
                        Foreground="{DynamicResource AccentSoft}" />
                </StackPanel>

                <!--  Cards grid (3 colonnes)  -->
                <ItemsControl
                    Margin="32,12,32,0"
                    ItemsSource="{Binding Articles}"
                    Visibility="{Binding IsInitialLoading, Converter={StaticResource BoolToVisNot}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="3" Rows="1" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Height="185"
                                Margin="0,0,10,0"
                                BorderBrush="{DynamicResource Border1}"
                                BorderThickness="1"
                                ClipToBounds="True"
                                CornerRadius="0"
                                Cursor="Hand">
                                <Border.InputBindings>
                                    <MouseBinding
                                        Command="{Binding DataContext.OpenArticleCommand, ElementName=ThisControl}"
                                        CommandParameter="{Binding}"
                                        MouseAction="LeftClick" />
                                </Border.InputBindings>
                                <Grid>
                                    <Border>
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Offset="0" Color="{DynamicResource C_HeroBgStart}" />
                                                <GradientStop Offset="1" Color="{DynamicResource C_HeroBgMid}" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <Image
                                        beh:AsyncImageBehavior.Source="{Binding ImageUrl}"
                                        Stretch="UniformToFill"
                                        Visibility="{Binding HasHeroImage, Converter={StaticResource BoolToVis}}" />
                                    <Border VerticalAlignment="Bottom">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Offset="0" Color="#00000000" />
                                                <GradientStop Offset="1" Color="{DynamicResource C_NewsCardOverlay}" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <StackPanel Margin="12,0,12,12">
                                            <Border
                                                Margin="0,0,0,5"
                                                Padding="7,2"
                                                HorizontalAlignment="Left"
                                                Background="{DynamicResource AccentPressedBg}"
                                                CornerRadius="0">
                                                <TextBlock
                                                    FontSize="9"
                                                    FontWeight="Bold"
                                                    Foreground="{DynamicResource AccentSoft}"
                                                    Text="{Binding Category}" />
                                            </Border>
                                            <TextBlock
                                                MaxHeight="36"
                                                Margin="0,0,0,3"
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource OnAccentText}"
                                                Text="{Binding Title}"
                                                TextWrapping="Wrap" />
                                            <TextBlock
                                                FontSize="10"
                                                Foreground="{DynamicResource Text2}"
                                                Text="{Binding ExcerptText}"
                                                TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>