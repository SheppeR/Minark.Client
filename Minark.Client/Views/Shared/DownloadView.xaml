<UserControl
    x:Class="Minark.Client.Views.Shared.DownloadView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern">

    <Grid>
        <Border Background="{DynamicResource Surface0}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="60" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--  HEADER  -->
                <StackPanel Grid.Row="0" Margin="32,28,32,0">
                    <TextBlock
                        Margin="0,0,0,6"
                        FontSize="22"
                        FontWeight="Bold"
                        Foreground="{DynamicResource Text1}"
                        Text="Téléchargements" />
                    <TextBlock
                        Margin="0,0,0,24"
                        FontSize="12"
                        Foreground="{DynamicResource Text3}"
                        Text="Gère le téléchargement de ton jeu" />
                </StackPanel>

                <!--  CONTENU  -->
                <Grid
                    Grid.Row="1"
                    MaxWidth="640"
                    Margin="32,0"
                    VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="20" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  Titre + versions  -->
                    <StackPanel
                        Grid.Row="0"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal">
                        <Border
                            Width="64"
                            Height="64"
                            Margin="0,0,20,0"
                            CornerRadius="16">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Offset="0" Color="{DynamicResource C_Accent1}" />
                                    <GradientStop Offset="1" Color="{DynamicResource C_Accent2}" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <ui:FontIcon
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="28"
                                Foreground="White"
                                Glyph="&#xE896;" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock
                                FontSize="26"
                                FontWeight="Bold"
                                Foreground="{DynamicResource Text1}"
                                Text="Minark" />
                            <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                                <TextBlock FontSize="12" Foreground="{DynamicResource Text3}">
                                    <Run Text="Installé : " />
                                    <Run
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AccentText}"
                                        Text="{Binding InstalledVersion, Mode=OneWay}" />
                                </TextBlock>
                                <TextBlock
                                    Margin="12,0,0,0"
                                    FontSize="12"
                                    Foreground="{DynamicResource Text3}"
                                    Visibility="{Binding RemoteVersion, Converter={StaticResource StringToVis}}">
                                    <Run Text="Disponible : " />
                                    <Run
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource Text2}"
                                        Text="{Binding RemoteVersion, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!--  Carte statut  -->
                    <Border
                        Grid.Row="2"
                        Padding="20,16"
                        CornerRadius="12">
                        <Border.Background>
                            <SolidColorBrush Color="{DynamicResource C_Surface1}" />
                        </Border.Background>
                        <StackPanel>
                            <TextBlock
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource Text1}"
                                Text="{Binding StatusText}"
                                TextWrapping="Wrap" />
                            <TextBlock
                                Margin="0,4,0,0"
                                FontSize="12"
                                Foreground="{DynamicResource Text3}"
                                Text="{Binding SubStatusText}"
                                TextTrimming="CharacterEllipsis"
                                Visibility="{Binding SubStatusText, Converter={StaticResource StringToVis}}" />
                            <TextBlock
                                Margin="0,3,0,0"
                                FontFamily="Consolas"
                                FontSize="11"
                                Foreground="{DynamicResource Text3}"
                                Text="{Binding CurrentFile}"
                                TextTrimming="CharacterEllipsis"
                                Visibility="{Binding CurrentFile, Converter={StaticResource StringToVis}}" />
                        </StackPanel>
                    </Border>

                    <!--  Barre : fichier courant  -->
                    <Grid Grid.Row="4" Visibility="{Binding IsWorking, Converter={StaticResource BoolToVis}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="4" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <TextBlock
                                HorizontalAlignment="Left"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource Text2}"
                                Text="Fichier en cours" />
                            <TextBlock
                                HorizontalAlignment="Right"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AccentText}"
                                Text="{Binding FileProgressText}" />
                        </Grid>
                        <Border
                            Grid.Row="2"
                            Height="14"
                            Background="{DynamicResource Surface2}"
                            CornerRadius="7" />
                        <ProgressBar
                            Grid.Row="2"
                            Height="14"
                            Background="Transparent"
                            BorderThickness="0"
                            Value="{Binding FileProgressValue, Mode=OneWay}">
                            <ProgressBar.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Offset="0" Color="{DynamicResource C_Accent1}" />
                                    <GradientStop Offset="1" Color="{DynamicResource C_Accent2}" />
                                </LinearGradientBrush>
                            </ProgressBar.Foreground>
                        </ProgressBar>
                    </Grid>

                    <!--  Barre : globale  -->
                    <Grid Grid.Row="6" Visibility="{Binding IsWorking, Converter={StaticResource BoolToVis}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="4" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <TextBlock
                                HorizontalAlignment="Left"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource Text2}"
                                Text="Total" />
                            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                <TextBlock
                                    Margin="0,0,8,0"
                                    FontSize="11"
                                    Foreground="{DynamicResource Text2}"
                                    Text="{Binding BytesSummary}" />
                                <TextBlock
                                    FontSize="11"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource AccentText}">
                                    <Run Text="{Binding ProgressValue, Mode=OneWay, StringFormat={}{0:F0}}" />
                                    <Run Text="%" />
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                        <Border
                            Grid.Row="2"
                            Height="14"
                            Background="{DynamicResource Surface2}"
                            CornerRadius="7" />
                        <ProgressBar
                            Grid.Row="2"
                            Height="14"
                            Background="Transparent"
                            BorderThickness="0"
                            IsIndeterminate="{Binding IsIndeterminate, Mode=OneWay}"
                            Value="{Binding ProgressValue, Mode=OneWay}">
                            <ProgressBar.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Offset="0" Color="{DynamicResource C_Accent1}" />
                                    <GradientStop Offset="1" Color="{DynamicResource C_Accent2}" />
                                </LinearGradientBrush>
                            </ProgressBar.Foreground>
                        </ProgressBar>
                    </Grid>

                    <!--  Boutons  -->
                    <StackPanel
                        Grid.Row="8"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal">

                        <!--  TÉLÉCHARGER  -->
                        <Button
                            Width="200"
                            Height="44"
                            Margin="0,0,12,0"
                            Command="{Binding DownloadCommand}"
                            Style="{StaticResource AccentBtn}"
                            Visibility="{Binding CanDownload, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon
                                    Margin="0,0,8,0"
                                    FontSize="14"
                                    Glyph="&#xE896;" />
                                <TextBlock
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Text="TÉLÉCHARGER" />
                            </StackPanel>
                        </Button>

                        <!--  VÉRIFIER MAJ  -->
                        <Button
                            Width="200"
                            Height="44"
                            Margin="0,0,12,0"
                            Command="{Binding CheckForUpdatesCommand}"
                            Style="{StaticResource AccentBtn}"
                            Visibility="{Binding CanPlay, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon
                                    Margin="0,0,8,0"
                                    FontSize="14"
                                    Glyph="&#xE895;" />
                                <TextBlock
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Text="Vérifier les mises à jour" />
                            </StackPanel>
                        </Button>

                        <!--  PAUSE  -->
                        <Button
                            Width="130"
                            Height="44"
                            Margin="0,0,12,0"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource AccentBtn}"
                            Visibility="{Binding CanCancel, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon
                                    Margin="0,0,6,0"
                                    FontSize="13"
                                    Glyph="&#xE769;" />
                                <TextBlock FontSize="13" Text="Pause" />
                            </StackPanel>
                        </Button>

                        <!--  REPRENDRE  -->
                        <Button
                            Width="160"
                            Height="44"
                            Margin="0,0,12,0"
                            Command="{Binding ResumeCommand}"
                            Style="{StaticResource AccentBtn}"
                            Visibility="{Binding CanResume, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon
                                    Margin="0,0,8,0"
                                    FontSize="14"
                                    Glyph="&#xE768;" />
                                <TextBlock
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Text="Reprendre" />
                            </StackPanel>
                        </Button>

                        <!--  Spinner  -->
                        <ui:ProgressRing
                            Width="32"
                            Height="32"
                            Foreground="{DynamicResource AccentFill}"
                            IsActive="{Binding IsWorking, Mode=OneWay}"
                            Visibility="{Binding IsWorking, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>

                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>