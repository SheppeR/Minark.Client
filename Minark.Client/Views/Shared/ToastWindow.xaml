<Window x:Class="Minark.Client.Views.Shared.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize">

    <Window.Resources>
        <ResourceDictionary />
    </Window.Resources>

    <Grid Width="300">
        <Border x:Name="Card" Background="{DynamicResource Surface2}"
                BorderBrush="{DynamicResource Border1}"
                BorderThickness="1" CornerRadius="0"
                Padding="0">
            <Border.Effect>
                <DropShadowEffect Color="{DynamicResource C_ToastShadow}" BlurRadius="28" ShadowDepth="0" Opacity="0.6" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="3" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Accent bar -->
                <Border Grid.Row="0" CornerRadius="0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="{DynamicResource C_Accent1}" Offset="0" />
                            <GradientStop Color="{DynamicResource C_Accent2}" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <Border Grid.Row="1" Padding="14,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Avatar -->
                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="0"
                                Margin="0,0,12,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="{DynamicResource C_Accent1}" Offset="0" />
                                    <GradientStop Color="{DynamicResource C_Accent2}" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="{Binding Initial}"
                                       FontSize="13" FontWeight="Bold" Foreground="{DynamicResource OnAccentText}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Title}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ToastTitle}" Margin="0,0,0,2" />
                            <TextBlock Text="{Binding Body}"
                                       FontSize="12" Foreground="{DynamicResource ToastBody}"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="200" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
        <!-- Close button overlay -->
        <Button Command="{Binding CloseCommand}"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Width="22" Height="22" Margin="0,6,6,0"
                Background="{DynamicResource Surface3}" BorderThickness="0"
                Cursor="Hand" Padding="0"
                FontSize="11" FontWeight="Bold" Foreground="{DynamicResource Text2}">
            <TextBlock Text="✕" VerticalAlignment="Center" HorizontalAlignment="Center" />
        </Button>
    </Grid>
</Window>