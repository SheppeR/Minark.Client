<Window x:Class="Minark.Client.Views.Windows.InviteNotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="110" Width="320"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="Manual"
        Topmost="True"
        Title="Invitation">

    <Border Background="{DynamicResource Surface2}"
            BorderBrush="{DynamicResource Border1}"
            BorderThickness="1" CornerRadius="0"
            Padding="0">
        <Border.Effect>
            <DropShadowEffect Color="{DynamicResource C_ToastShadow}" BlurRadius="24" ShadowDepth="0" Opacity="0.55" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="3" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Accent top bar -->
            <Border Grid.Row="0" CornerRadius="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="{DynamicResource C_Accent1}" Offset="0" />
                        <GradientStop Color="{DynamicResource C_Accent2}" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Border Grid.Row="1" Padding="14,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <!-- Square avatar -->
                        <Border Width="36" Height="36" CornerRadius="0"
                                Margin="0,0,10,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="{DynamicResource C_Accent1}" Offset="0" />
                                    <GradientStop Color="{DynamicResource C_Accent2}" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="{Binding Initials}"
                                       FontSize="13" FontWeight="Bold" Foreground="{DynamicResource OnAccentText}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Invitation de " FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource ToastTitle}" />
                                <TextBlock Text="{Binding FromUsername}" FontSize="12" FontWeight="Bold"
                                           Foreground="{DynamicResource AccentSoft}" />
                            </StackPanel>
                            <TextBlock Text="veut vous ajouter comme ami"
                                       FontSize="11" Foreground="{DynamicResource ToastBody}" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Orientation="Horizontal"
                                HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button Style="{StaticResource DangerButton}"
                                Content="Refuser" Padding="10,5"
                                FontSize="11" Margin="0,0,6,0"
                                Command="{Binding DeclineCommand}" />
                        <Button Style="{StaticResource AccentBtn}"
                                Content="Accepter" Padding="10,5"
                                FontSize="11"
                                Command="{Binding AcceptCommand}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>