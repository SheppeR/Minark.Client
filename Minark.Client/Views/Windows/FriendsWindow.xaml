<Window x:Class="Minark.Client.Views.Windows.FriendsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:beh="clr-namespace:Minark.Client.Behaviors"
        xmlns:packets="clr-namespace:Minark.Shared.Packets;assembly=Minark.Shared"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
        Title="Minark — Amis"
        Height="660" Width="360"
        MinHeight="420" MinWidth="320"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="Manual"
        ui:TitleBar.Height="46"
        ui:TitleBar.IsIconVisible="False"
        ui:TitleBar.ExtendViewIntoTitleBar="True"
        ui:WindowHelper.ApplyNoise="False"
        ui:WindowHelper.CornerStyle="DoNotRound"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:WindowHelper.FixMaximizedWindow="True"
        ui:WindowHelper.SystemBackdropType="Mica">

    <Window.Resources>
        <ResourceDictionary>
            <!-- Shared friend item template (Online + Offline) -->
            <DataTemplate x:Key="FriendItemTemplate">
                <Button Style="{StaticResource FriendItemBtn}"
                        MouseRightButtonDown="FriendList_RightClick"
                        Tag="{Binding Dto}">
                    <Button.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick"
                                      Command="{Binding DataContext.OpenChatCommand,
                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                      CommandParameter="{Binding Dto}" />
                    </Button.InputBindings>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <!-- Avatar with photo + status dot -->
                        <Grid Grid.Column="0" Width="36" Height="36" Margin="0,0,10,0">
                            <!-- Fallback gradient when no photo -->
                            <Border Width="36" Height="36" CornerRadius="0"
                                    Background="{StaticResource AccentGradient}"
                                    Visibility="{Binding AvatarUrl, Converter={StaticResource StringToVis}, ConverterParameter=inverse}">
                                <TextBlock Text="{Binding Initials}"
                                           FontSize="12" FontWeight="Bold"
                                           Foreground="{DynamicResource OnAccentText}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <!-- Photo -->
                            <Border Width="36" Height="36" CornerRadius="0"
                                    Visibility="{Binding AvatarUrl, Converter={StaticResource StringToVis}}">
                                <Border.Background>
                                    <ImageBrush
                                        ImageSource="{Binding AvatarUrl, Converter={StaticResource UrlToImage}}"
                                        Stretch="UniformToFill" />
                                </Border.Background>
                            </Border>
                            <Ellipse Width="10" Height="10"
                                     HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                     Margin="0,0,-2,-2"
                                     StrokeThickness="2" Stroke="{DynamicResource Surface0}">
                                <Ellipse.Fill>
                                    <SolidColorBrush
                                        Color="{Binding Status, Converter={StaticResource StatusToColor}}" />
                                </Ellipse.Fill>
                            </Ellipse>
                        </Grid>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Username}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Text1}" />
                            <TextBlock
                                Text="{Binding Status, Converter={StaticResource StatusToString}}"
                                FontSize="11"
                                Foreground="{Binding Status, Converter={StaticResource StatusToBrush}}" />
                        </StackPanel>
                        <!-- Badge message non lu -->
                        <Ellipse Grid.Column="2"
                                 Width="8" Height="8" Margin="0,0,8,0"
                                 Fill="{DynamicResource AccentPrimary}"
                                 VerticalAlignment="Center"
                                 Visibility="{Binding HasUnread, Converter={StaticResource BoolToVis}}" />
                        <Button Grid.Column="3" Style="{StaticResource GhostBtn}"
                                Content="Discuter" Padding="10,5"
                                Command="{Binding DataContext.OpenChatCommand,
                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding Dto}" />
                    </Grid>
                </Button>
            </DataTemplate>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{DynamicResource Surface0}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46" />
                <RowDefinition Height="70" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ══ GRADIENT BANNER (covers titlebar + hero) ══════════════════ -->
            <Border Grid.Row="0" Grid.RowSpan="2"
                    Background="{DynamicResource AccentGradient}" />

            <!-- ══ HERO HEADER ══════════════════════════════════════════════ -->
            <Border Grid.Row="0" Grid.RowSpan="2" VerticalAlignment="Bottom"
                    Padding="18,0,18,12">

                <Grid Height="70">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Avatar with photo or initials fallback -->
                    <Grid Grid.Column="0" Width="62" Height="62" Margin="0,0,14,0">
                        <!-- Fallback gradient + initials -->
                        <Border Width="62" Height="62" CornerRadius="0"
                                Background="{DynamicResource OnAccentChipStrong}" BorderThickness="2"
                                BorderBrush="{DynamicResource OnAccentBorderStrong}"
                                Visibility="{Binding AvatarUrl, Converter={StaticResource StringToVis}, ConverterParameter=inverse}">
                            <TextBlock Text="{Binding Initials}"
                                       FontSize="20" FontWeight="Bold" Foreground="{DynamicResource OnAccentText}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <!-- Real avatar photo -->
                        <Border Width="62" Height="62" CornerRadius="0"
                                BorderThickness="2" BorderBrush="{DynamicResource OnAccentBorderStrong}"
                                Visibility="{Binding AvatarUrl, Converter={StaticResource StringToVis}}">
                            <Border.Background>
                                <ImageBrush
                                    ImageSource="{Binding AvatarUrl, Converter={StaticResource UrlToImage}}"
                                    Stretch="UniformToFill" />
                            </Border.Background>
                        </Border>
                    </Grid>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Username}" FontSize="15" FontWeight="Bold"
                                   Foreground="{DynamicResource OnAccentText}" />
                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                            <Ellipse Width="7" Height="7" Margin="0,0,5,0"
                                     VerticalAlignment="Center">
                                <Ellipse.Fill>
                                    <SolidColorBrush
                                        Color="{Binding CurrentStatus, Converter={StaticResource StatusToColor}}" />
                                </Ellipse.Fill>
                            </Ellipse>
                            <TextBlock Text="{Binding StatusText}"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource OnAccentTextSoft}" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Search toggle button -->
                    <Button Grid.Column="2" Style="{StaticResource IconBtn}"
                            Background="{DynamicResource OnAccentChip}" BorderBrush="{DynamicResource OnAccentChip}"
                            VerticalAlignment="Center" Margin="0,0,6,0"
                            Command="{Binding ToggleSearchCommand}" ToolTip="Rechercher un ami">
                        <ui:FontIcon Glyph="&#xE721;" FontSize="11" Foreground="{DynamicResource OnAccentText}" />
                    </Button>

                    <!-- Status change button -->
                    <Button Grid.Column="3" Style="{StaticResource IconBtn}"
                            Background="{DynamicResource OnAccentChip}" BorderBrush="{DynamicResource OnAccentChip}"
                            VerticalAlignment="Center"
                            beh:ContextMenuButtonBehavior.OpenOnClick="True" ToolTip="Changer le statut">
                        <ui:FontIcon Glyph="&#xE70D;" FontSize="10" Foreground="{DynamicResource OnAccentText}" />
                        <Button.ContextMenu>
                            <ContextMenu x:Name="StatusMenu">
                                <MenuItem Header="En ligne" Command="{Binding ChangeStatusCommand}"
                                          CommandParameter="{x:Static packets:UserStatus.Online}">
                                    <MenuItem.Icon>
                                        <Ellipse Width="10" Height="10" Fill="{DynamicResource StatusOnline}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Occupé" Command="{Binding ChangeStatusCommand}"
                                          CommandParameter="{x:Static packets:UserStatus.Busy}">
                                    <MenuItem.Icon>
                                        <Ellipse Width="10" Height="10" Fill="{DynamicResource StatusBusy}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Absent" Command="{Binding ChangeStatusCommand}"
                                          CommandParameter="{x:Static packets:UserStatus.Away}">
                                    <MenuItem.Icon>
                                        <Ellipse Width="10" Height="10" Fill="{DynamicResource StatusAway}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Invisible" Command="{Binding ChangeStatusCommand}"
                                          CommandParameter="{x:Static packets:UserStatus.Offline}">
                                    <MenuItem.Icon>
                                        <Ellipse Width="10" Height="10" Fill="{DynamicResource StatusOffline}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </Grid>
            </Border>

            <!-- ══ STATS STRIP ═══════════════════════════════════════════════ -->
            <Border Grid.Row="2" Padding="18,10,18,14"
                    Background="{DynamicResource AccentGradient}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{DynamicResource OnAccentSubtle}" CornerRadius="0"
                            Padding="0,8">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding FriendsList.Count}"
                                       FontSize="18" FontWeight="Black"
                                       Foreground="{DynamicResource OnAccentText}" HorizontalAlignment="Center" />
                            <TextBlock Text="AMIS" FontSize="9" FontWeight="Bold"
                                       Foreground="{DynamicResource OnAccentTextMuted}" HorizontalAlignment="Center"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="{DynamicResource OnAccentSubtle}" CornerRadius="0"
                            Padding="0,8">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding OnlineCount}"
                                       FontSize="18" FontWeight="Black"
                                       Foreground="{DynamicResource OnAccentText}" HorizontalAlignment="Center" />
                            <TextBlock Text="EN LIGNE" FontSize="9" FontWeight="Bold"
                                       Foreground="{DynamicResource OnAccentTextMuted}" HorizontalAlignment="Center"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="4" Background="{DynamicResource OnAccentSubtle}" CornerRadius="0"
                            Padding="0,8">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding PendingCount}"
                                       FontSize="18" FontWeight="Black"
                                       Foreground="{DynamicResource OnAccentText}" HorizontalAlignment="Center" />
                            <TextBlock Text="EN ATTENTE" FontSize="9" FontWeight="Bold"
                                       Foreground="{DynamicResource OnAccentTextMuted}" HorizontalAlignment="Center"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ══ SEARCH BAR ════════════════════════════════════════════════ -->
            <Border Grid.Row="3" x:Name="SearchBarPanel"
                    Padding="12,10" Visibility="{Binding IsSearchVisible, Converter={StaticResource BoolToVis}}"
                    Background="{DynamicResource Surface1}"
                    BorderBrush="{DynamicResource Border1}"
                    BorderThickness="0,0,0,1">
                <Border Background="{DynamicResource Surface3}"
                        BorderBrush="{DynamicResource Border1}"
                        BorderThickness="1" CornerRadius="0" Padding="10,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:FontIcon Grid.Column="0" Glyph="&#xE721;" FontSize="12"
                                     Foreground="{DynamicResource Text3}"
                                     Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" x:Name="SearchBox"
                                 Style="{StaticResource ChatInputBox}"
                                 beh:FocusOnVisibilityBehavior.FocusOnVisible="True"
                                 Height="36"
                                 ui:ControlHelper.PlaceholderText="Rechercher un ami..." />
                        <Button Grid.Column="2" Command="{Binding ToggleSearchCommand}"
                                Background="Transparent" BorderThickness="0"
                                Padding="6,0" ToolTip="Fermer la recherche">
                            <ui:FontIcon Glyph="&#xE711;" FontSize="12"
                                         Foreground="{DynamicResource Text3}" />
                        </Button>
                    </Grid>
                </Border>
            </Border>

            <!-- ══ FRIEND LIST ═══════════════════════════════════════════════ -->
            <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto"
                          Background="{DynamicResource Surface0}">
                <StackPanel>

                    <!-- Add friend panel -->
                    <Border x:Name="AddFriendPanel"
                            Visibility="{Binding IsAddPanelVisible, Converter={StaticResource BoolToVis}}"
                            Background="{DynamicResource Surface2}"
                            BorderBrush="{DynamicResource Border1}"
                            BorderThickness="0,0,0,1" Padding="14,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{DynamicResource Surface3}"
                                    BorderBrush="{DynamicResource Border1}"
                                    BorderThickness="1" CornerRadius="0" Padding="10,0">
                                <TextBox x:Name="AddFriendBox" Style="{StaticResource ChatInputBox}"
                                         Height="34"
                                         ui:ControlHelper.PlaceholderText="Nom d'utilisateur..."
                                         Text="{Binding SearchUsername, UpdateSourceTrigger=PropertyChanged}" />
                            </Border>
                            <Button Grid.Column="2" Style="{StaticResource AccentBtn}"
                                    Padding="14,6" Content="Inviter"
                                    Command="{Binding AddFriendCommand}" />
                        </Grid>
                    </Border>

                    <!-- Pending invites -->
                    <ItemsControl ItemsSource="{Binding PendingInvites}"
                                  Visibility="{Binding HasPendingInvites, Converter={StaticResource BoolToVis}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource Surface2}"
                                        BorderBrush="{DynamicResource AccentBorderSoft}" BorderThickness="0,0,0,1"
                                        Padding="14,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="34" Height="34"
                                                CornerRadius="0" Margin="0,0,10,0"
                                                Background="{DynamicResource Surface4}">
                                            <TextBlock
                                                Text="{Binding FromUsername, Converter={StaticResource StringToInitials}}"
                                                FontSize="12" FontWeight="Bold"
                                                Foreground="{DynamicResource AccentSoft}"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding FromUsername}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Text1}" />
                                            <TextBlock Text="veut vous ajouter"
                                                       FontSize="11" Foreground="{DynamicResource Text2}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <Button Style="{StaticResource GhostBtn}"
                                                    Content="✓" Padding="8,4"
                                                    Command="{Binding DataContext.AcceptInviteCommand,
                                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}" />
                                            <Button Style="{StaticResource DangerButton}"
                                                    Content="✕" Padding="8,4" Margin="6,0,0,0"
                                                    Command="{Binding DataContext.DeclineInviteCommand,
                                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- ── EN LIGNE ── -->
                    <Border Padding="14,10,14,4"
                            Visibility="{Binding HasOnlineFriends, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="EN LIGNE" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource Text3}" VerticalAlignment="Center" />
                            <Border Background="{DynamicResource Surface3}" CornerRadius="0"
                                    Padding="7,1" Margin="6,0,0,0">
                                <TextBlock Text="{Binding OnlineCount}" FontSize="10"
                                           Foreground="{DynamicResource Text2}" />
                            </Border>
                        </StackPanel>
                    </Border>

                    <ItemsControl ItemsSource="{Binding OnlineFriends}"
                                  ItemTemplate="{StaticResource FriendItemTemplate}"
                                  Visibility="{Binding HasOnlineFriends, Converter={StaticResource BoolToVis}}" />

                    <!-- ── HORS LIGNE ── -->
                    <Border Padding="14,10,14,4"
                            Visibility="{Binding HasOfflineFriends, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="HORS LIGNE" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource Text3}" VerticalAlignment="Center" />
                            <Border Background="{DynamicResource Surface3}" CornerRadius="0"
                                    Padding="7,1" Margin="6,0,0,0">
                                <TextBlock Text="{Binding OfflineFriends.Count}" FontSize="10"
                                           Foreground="{DynamicResource Text2}" />
                            </Border>
                        </StackPanel>
                    </Border>

                    <ItemsControl ItemsSource="{Binding OfflineFriends}"
                                  ItemTemplate="{StaticResource FriendItemTemplate}"
                                  Visibility="{Binding HasOfflineFriends, Converter={StaticResource BoolToVis}}" />

                </StackPanel>
            </ScrollViewer>

            <!-- ══ FOOTER ════════════════════════════════════════════════════ -->
            <Border Grid.Row="5" Padding="14,10"
                    Background="{DynamicResource Surface1}"
                    BorderBrush="{DynamicResource Border1}"
                    BorderThickness="0,1,0,0">
                <Button Style="{StaticResource AccentBtn}"
                        HorizontalAlignment="Right"
                        Padding="14,7" Command="{Binding ToggleAddPanelCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="+" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource OnAccentText}" Margin="0,0,6,0"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="Ajouter un ami" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource OnAccentText}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Border>

        </Grid>
    </Border>
</Window>