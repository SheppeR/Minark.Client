<Window x:Class="Minark.Client.Views.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:beh="clr-namespace:Minark.Client.Behaviors"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
        Title="Minark"
        Width="1200" Height="760"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        ui:TitleBar.Height="46"
        ui:TitleBar.IsIconVisible="False" ui:TitleBar.ExtendViewIntoTitleBar="True"
        ui:WindowHelper.ApplyNoise="False"
        ui:WindowHelper.CornerStyle="DoNotRound"
        ui:WindowHelper.SystemBackdropType="Mica"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:WindowHelper.FixMaximizedWindow="True">

    <Grid>
        <!-- Fantasy bg -->
        <Border IsHitTestVisible="False" Panel.ZIndex="100">
            <Border.Background>
                <ImageBrush
                    ImageSource="pack://application:,,,/Minark.Client;component/Assets/bg_fantasy2.png"
                    Stretch="UniformToFill" Opacity="0.08" />
            </Border.Background>
        </Border>

        <ContentControl x:Name="RootContent" Margin="0,0,0,0"
                        beh:FlipTransitionBehavior.IsEnabled="True" />

        <!-- Offline banner -->
        <Border x:Name="OfflineBanner"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,8,150,0" CornerRadius="0" Padding="12,7"
                Visibility="{Binding IsOffline, Converter={StaticResource BoolToVis}}" Panel.ZIndex="999">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="{DynamicResource C_OfflineBannerStart}" Offset="0" />
                    <GradientStop Color="{DynamicResource C_OfflineBannerEnd}" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="{DynamicResource C_ToastShadow}" BlurRadius="16" ShadowDepth="0" Opacity="0.5" />
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="OfflineDot" Width="8" Height="8"
                         Fill="{DynamicResource Danger}" VerticalAlignment="Center" Margin="0,0,8,0">
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="1" To="0.2" Duration="0:0:0.8"
                                                     AutoReverse="True">
                                        <DoubleAnimation.EasingFunction>
                                            <SineEase EasingMode="EaseInOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>
                <TextBlock FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource OfflineBannerText}" VerticalAlignment="Center"
                           Text="Serveur hors ligne" />
            </StackPanel>
        </Border>
    </Grid>
</Window>