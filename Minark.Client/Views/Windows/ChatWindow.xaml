<Window
    x:Class="Minark.Client.Views.Windows.ChatWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:beh="clr-namespace:Minark.Client.Behaviors"
    xmlns:controls="clr-namespace:Minark.Client.Controls"
    xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    xmlns:viewModels="clr-namespace:Minark.Client.ViewModels"
    x:Name="ChatWindowRoot"
    Title="{Binding FriendUsername, StringFormat='Chat — {0}'}"
    Width="820"
    Height="680"
    MinWidth="560"
    MinHeight="440"
    beh:ChatInputBehavior.SendCommand="{Binding SendCommand}"
    ui:TitleBar.ExtendViewIntoTitleBar="True"
    ui:TitleBar.Height="46"
    ui:TitleBar.IsIconVisible="False"
    ui:WindowHelper.ApplyNoise="False"
    ui:WindowHelper.CornerStyle="DoNotRound"
    ui:WindowHelper.FixMaximizedWindow="True"
    ui:WindowHelper.SystemBackdropType="Mica"
    ui:WindowHelper.UseModernWindowStyle="True"
    WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <ResourceDictionary>

            <!--  Typing animation  -->
            <Storyboard x:Key="TypingDots" RepeatBehavior="Forever">
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot1" Storyboard.TargetProperty="Opacity">
                    <DiscreteDoubleKeyFrame KeyTime="0:0:0.0" Value="0.3" />
                    <DiscreteDoubleKeyFrame KeyTime="0:0:0.3" Value="1.0" />
                    <DiscreteDoubleKeyFrame KeyTime="0:0:0.9" Value="0.3" />
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot2" Storyboard.TargetProperty="Opacity">
                    <DiscreteDoubleKeyFrame KeyTime="0:0:0.0" Value="0.3" />
                    <DiscreteDoubleKeyFrame KeyTime="0:0:0.4" Value="1.0" />
                    <DiscreteDoubleKeyFrame KeyTime="0:0:0.9" Value="0.3" />
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot3" Storyboard.TargetProperty="Opacity">
                    <DiscreteDoubleKeyFrame KeyTime="0:0:0.0" Value="0.3" />
                    <DiscreteDoubleKeyFrame KeyTime="0:0:0.5" Value="1.0" />
                    <DiscreteDoubleKeyFrame KeyTime="0:0:0.9" Value="0.3" />
                </DoubleAnimationUsingKeyFrames>
            </Storyboard>

            <!--  Message DataTemplate selector  -->
        </ResourceDictionary>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard x:Name="TypingStoryboard" Storyboard="{StaticResource TypingDots}" />
        </EventTrigger>
    </Window.Triggers>

    <Grid Background="{DynamicResource Surface0}">

        <!--  Emoji picker popup — at root Grid level so it can float above all content  -->
        <Popup
            x:Name="EmojiPopup"
            AllowsTransparency="True"
            Placement="MousePoint"
            StaysOpen="False">
            <Border
                Background="{DynamicResource Surface2}"
                BorderBrush="{DynamicResource Border1}"
                BorderThickness="1"
                CornerRadius="0">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="24"
                        Opacity="0.5"
                        ShadowDepth="0"
                        Color="{DynamicResource C_ToastShadow}" />
                </Border.Effect>
                <controls:EmojiPickerControl x:Name="EmojiPickerCtrl" EmojiSelected="EmojiPicker_EmojiSelected" />
            </Border>
        </Popup>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46" />
                <RowDefinition Height="70" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  ══ GRADIENT BANNER (covers titlebar + header) ═══════════════  -->
            <Border
                Grid.Row="0"
                Grid.RowSpan="2"
                Background="{DynamicResource AccentGradient}" />

            <!--  ══ HEADER ══════════════════════════════════════════════════  -->
            <Border
                Grid.Row="0"
                Grid.RowSpan="2"
                Padding="16,0,16,12"
                VerticalAlignment="Bottom"
                BorderBrush="{DynamicResource ShadowEdge}"
                BorderThickness="0,0,0,1">
                <Grid Height="70">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <!--  Square avatar + status  -->
                        <Grid
                            Width="62"
                            Height="62"
                            Margin="0,0,14,0">
                            <!--  Fallback initials  -->
                            <Border
                                Width="62"
                                Height="62"
                                Background="{DynamicResource OnAccentChipStrong}"
                                BorderBrush="{DynamicResource OnAccentBorderStrong}"
                                BorderThickness="2"
                                CornerRadius="0"
                                Visibility="{Binding FriendAvatarUrl, Converter={StaticResource StringToVis}, ConverterParameter=inverse}">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="20"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource OnAccentText}"
                                    Text="{Binding FriendInitials}" />
                            </Border>
                            <!--  Real avatar photo  -->
                            <Border
                                Width="62"
                                Height="62"
                                BorderBrush="{DynamicResource OnAccentBorderStrong}"
                                BorderThickness="2"
                                CornerRadius="0"
                                Visibility="{Binding FriendAvatarUrl, Converter={StaticResource StringToVis}}">
                                <Border.Background>
                                    <ImageBrush
                                        ImageSource="{Binding FriendAvatarUrl, Converter={StaticResource UrlToImage}}"
                                        Stretch="UniformToFill" />
                                </Border.Background>
                            </Border>
                            <Ellipse
                                Width="14"
                                Height="14"
                                Margin="0,0,-2,-2"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Stroke="{DynamicResource Surface1}"
                                StrokeThickness="2">
                                <Ellipse.Fill>
                                    <SolidColorBrush
                                        Color="{Binding FriendStatus, Converter={StaticResource StatusToColor}}" />
                                </Ellipse.Fill>
                            </Ellipse>
                        </Grid>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock
                                FontSize="16"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource OnAccentText}"
                                Text="{Binding FriendUsername}" />
                            <Grid>
                                <!--  Status text  -->
                                <StackPanel Orientation="Horizontal"
                                            Visibility="{Binding FriendIsTyping, Converter={StaticResource BoolToVisNot}}">
                                    <TextBlock
                                        FontSize="11"
                                        Foreground="{Binding FriendStatus, Converter={StaticResource StatusToBrush}}"
                                        Text="{Binding FriendStatusText}" />
                                </StackPanel>
                                <!--  Typing indicator  -->
                                <StackPanel Orientation="Horizontal"
                                            Visibility="{Binding FriendIsTyping, Converter={StaticResource BoolToVis}}">
                                    <TextBlock
                                        Margin="0,0,4,0"
                                        FontSize="11"
                                        FontStyle="Italic"
                                        Foreground="{DynamicResource AccentSoft}"
                                        Text="en train d'écrire" />
                                    <Ellipse
                                        x:Name="Dot1"
                                        Width="4"
                                        Height="4"
                                        Margin="1,0"
                                        VerticalAlignment="Center"
                                        Fill="{DynamicResource AccentSoft}" />
                                    <Ellipse
                                        x:Name="Dot2"
                                        Width="4"
                                        Height="4"
                                        Margin="1,0"
                                        VerticalAlignment="Center"
                                        Fill="{DynamicResource AccentSoft}" />
                                    <Ellipse
                                        x:Name="Dot3"
                                        Width="4"
                                        Height="4"
                                        Margin="1,0"
                                        VerticalAlignment="Center"
                                        Fill="{DynamicResource AccentSoft}" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </StackPanel>

                    <!--  Actions  -->
                    <StackPanel
                        Grid.Column="1"
                        Margin="0,0,0,12"
                        VerticalAlignment="Bottom"
                        Orientation="Horizontal">
                        <Button
                            Margin="0,0,6,0"
                            Background="{DynamicResource OnAccentChip}"
                            BorderBrush="{DynamicResource OnAccentChip}"
                            Command="{Binding ToggleSearchCommand}"
                            Style="{StaticResource IconBtn}"
                            ToolTip="Rechercher">
                            <ui:FontIcon
                                FontSize="13"
                                Foreground="{DynamicResource OnAccentText}"
                                Glyph="&#xE721;" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!--  Search bar  -->
            <Border
                Grid.Row="2"
                Padding="14,8"
                Background="{DynamicResource Surface2}"
                BorderBrush="{DynamicResource Border1}"
                BorderThickness="0,0,0,1"
                Visibility="{Binding IsSearchMode, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Grid.Column="0"
                        Padding="10,0"
                        Background="{DynamicResource Surface3}"
                        BorderBrush="{DynamicResource Border1}"
                        BorderThickness="1"
                        CornerRadius="0">
                        <TextBox
                            x:Name="SearchBox"
                            Height="34"
                            beh:FocusOnVisibilityBehavior.FocusOnVisible="True"
                            ui:ControlHelper.PlaceholderText="Rechercher dans la conversation..."
                            Style="{StaticResource ChatInputBox}"
                            Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" />
                    </Border>
                    <Button
                        Grid.Column="2"
                        Command="{Binding ClearSearchCommand}"
                        Content="Effacer"
                        Style="{StaticResource GhostBtn}" />
                </Grid>
            </Border>

            <!--  ══ MESSAGES ════════════════════════════════════════════════  -->
            <ScrollViewer
                x:Name="MessagesScroll"
                Grid.Row="3"
                Padding="16,12,28,12"
                beh:ChatScrollBehavior.LoadMoreCommand="{Binding LoadMoreCommand}"
                beh:ChatScrollBehavior.Messages="{Binding Messages}"
                Background="{DynamicResource Surface0}"
                VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <ItemsControl
                        x:Name="MessagesList"
                        beh:MessageContextMenuBehavior.DeleteCommand="{Binding DeleteMessageCommand}"
                        beh:MessageContextMenuBehavior.EditCommand="{Binding StartEditMessageCommand}"
                        beh:MessageContextMenuBehavior.OpenEmojiCommand="{Binding OpenEmojiPickerForCommand}"
                        ItemsSource="{Binding Messages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:ChatMessageViewModel}">
                                <Grid Margin="0,5">
                                    <StackPanel MaxWidth="480" Tag="{Binding}">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsOwn}" Value="True">
                                                        <Setter Property="HorizontalAlignment" Value="Right" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsOwn}" Value="False">
                                                        <Setter Property="HorizontalAlignment" Value="Left" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>

                                        <!--  Sender name (received only)  -->
                                        <TextBlock
                                            Margin="4,0,0,3"
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AccentSoft}"
                                            Text="{Binding FromUsername}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsOwn}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!--  Bubble  -->
                                        <Border Padding="13,10" Tag="{Binding}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Cursor" Value="Hand" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsOwn}" Value="True">
                                                            <Setter Property="CornerRadius" Value="16,16,4,16" />
                                                            <Setter Property="Background">
                                                                <Setter.Value>
                                                                    <LinearGradientBrush StartPoint="0,0"
                                                                            EndPoint="1,1">
                                                                        <GradientStop Offset="0"
                                                                                Color="{DynamicResource C_Accent1}" />
                                                                        <GradientStop Offset="1"
                                                                                Color="{DynamicResource C_AccentDark}" />
                                                                    </LinearGradientBrush>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Setter Property="Effect">
                                                                <Setter.Value>
                                                                    <DropShadowEffect
                                                                        BlurRadius="16"
                                                                        Opacity="0.30"
                                                                        ShadowDepth="0"
                                                                        Color="{DynamicResource C_Accent1}" />
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsOwn}" Value="False">
                                                            <Setter Property="CornerRadius" Value="16,16,16,4" />
                                                            <Setter Property="Background"
                                                                    Value="{DynamicResource Surface3}" />
                                                            <Setter Property="BorderBrush"
                                                                    Value="{DynamicResource Border1}" />
                                                            <Setter Property="BorderThickness" Value="1" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsDeleted}" Value="True">
                                                            <Setter Property="Opacity" Value="0.5" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <Grid>
                                                <emoji:TextBlock
                                                    FontSize="13"
                                                    FontStyle="{Binding IsDeleted, Converter={StaticResource BoolToItalic}}"
                                                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                    Text="{Binding DisplayContent}"
                                                    TextWrapping="Wrap"
                                                    Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisNot}}" />
                                                <StackPanel
                                                    Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}">
                                                    <TextBox
                                                        MinWidth="200"
                                                        Margin="0,0,0,6"
                                                        AcceptsReturn="True"
                                                        FontSize="13"
                                                        Text="{Binding EditBuffer, UpdateSourceTrigger=PropertyChanged}"
                                                        TextWrapping="Wrap">
                                                        <TextBox.InputBindings>
                                                            <KeyBinding
                                                                Key="Return"
                                                                Command="{Binding DataContext.ConfirmEditCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"
                                                                Modifiers="Ctrl" />
                                                            <KeyBinding
                                                                Key="Escape"
                                                                Command="{Binding DataContext.CancelEditCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}" />
                                                        </TextBox.InputBindings>
                                                    </TextBox>
                                                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                                        <Button
                                                            Margin="0,0,4,0"
                                                            Padding="8,3"
                                                            Command="{Binding DataContext.CancelEditCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Content="Annuler"
                                                            FontSize="11" />
                                                        <Button
                                                            Padding="8,3"
                                                            Command="{Binding DataContext.ConfirmEditCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Content="Enregistrer"
                                                            FontSize="11"
                                                            Style="{StaticResource AccentBtn}" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <!--  Reactions  -->
                                        <ItemsControl Margin="4,4,4,0" ItemsSource="{Binding Reactions}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border
                                                        Margin="0,0,4,3"
                                                        Padding="7,3"
                                                        BorderThickness="1"
                                                        CornerRadius="0"
                                                        Cursor="Hand"
                                                        PreviewMouseLeftButtonUp="ReactionBadge_Click">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasMine}"
                                                                            Value="True">
                                                                        <Setter Property="Background">
                                                                            <Setter.Value>
                                                                                <LinearGradientBrush StartPoint="0,0"
                                                                                    EndPoint="1,1">
                                                                                    <GradientStop Offset="0"
                                                                                        Color="{DynamicResource C_Accent1_2A}" />
                                                                                    <GradientStop Offset="1"
                                                                                        Color="{DynamicResource C_AccentDark_2A}" />
                                                                                </LinearGradientBrush>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                        <Setter Property="BorderBrush">
                                                                            <Setter.Value>
                                                                                <LinearGradientBrush StartPoint="0,0"
                                                                                    EndPoint="1,0">
                                                                                    <GradientStop Offset="0"
                                                                                        Color="{DynamicResource C_Accent1_CC}" />
                                                                                    <GradientStop Offset="1"
                                                                                        Color="{DynamicResource C_AccentDark_CC}" />
                                                                                </LinearGradientBrush>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                        <Setter Property="Effect">
                                                                            <Setter.Value>
                                                                                <DropShadowEffect
                                                                                    BlurRadius="8"
                                                                                    Opacity="0.45"
                                                                                    ShadowDepth="0"
                                                                                    Color="{DynamicResource C_Accent1}" />
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding HasMine}"
                                                                            Value="False">
                                                                        <Setter Property="Background"
                                                                                Value="{DynamicResource Surface3}" />
                                                                        <Setter Property="BorderBrush"
                                                                                Value="{DynamicResource Border1}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <StackPanel Orientation="Horizontal">
                                                            <emoji:TextBlock
                                                                Margin="0,0,4,0"
                                                                VerticalAlignment="Center"
                                                                FontSize="16"
                                                                Text="{Binding Emoji}" />
                                                            <TextBlock
                                                                VerticalAlignment="Center"
                                                                FontSize="11"
                                                                FontWeight="SemiBold"
                                                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                                Text="{Binding Count}" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!--  Timestamp  -->
                                        <StackPanel Margin="4,2,4,2" Orientation="Horizontal">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsOwn}" Value="True">
                                                            <Setter Property="HorizontalAlignment" Value="Right" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsOwn}" Value="False">
                                                            <Setter Property="HorizontalAlignment" Value="Left" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="10"
                                                Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                Text="{Binding SentAt, StringFormat='{}{0:HH:mm}'}" />
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="10"
                                                FontStyle="Italic"
                                                Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                Text=" · modifié">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEdited}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>

                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>


            <!--  ══ INPUT AREA ═══════════════════════════════════════════════  -->
            <Border
                Grid.Row="5"
                Padding="14,10"
                Background="{DynamicResource Surface1}"
                BorderBrush="{DynamicResource Border1}"
                BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="5" />
                        <ColumnDefinition Width="72" />
                    </Grid.ColumnDefinitions>

                    <!--  Zone de texte  -->
                    <Border
                        x:Name="InputBorder"
                        Grid.Column="0"
                        Padding="14,0"
                        Background="{DynamicResource Surface3}"
                        BorderBrush="{DynamicResource Border1}"
                        BorderThickness="1"
                        CornerRadius="0">
                        <TextBox
                            x:Name="MessageInput"
                            MinHeight="72"
                            MaxHeight="120"
                            VerticalContentAlignment="Center"
                            ui:ControlHelper.PlaceholderText="Écrire un message..."
                            AcceptsReturn="False"
                            Style="{StaticResource ChatInputBox}"
                            Text="{Binding InputMessage, UpdateSourceTrigger=PropertyChanged}"
                            TextWrapping="Wrap" />
                    </Border>

                    <!--  Bouton envoyer  -->
                    <Button
                        Grid.Column="2"
                        Width="72"
                        Height="72"
                        Margin="0"
                        Command="{Binding SendCommand}"
                        Style="{StaticResource SendBtn}">
                        <ui:FontIcon
                            FontSize="13"
                            Foreground="{DynamicResource OnAccentText}"
                            Glyph="&#xE724;" />
                    </Button>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</Window>