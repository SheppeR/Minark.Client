<UserControl x:Class="Minark.Client.Controls.RichEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
             xmlns:controls="clr-namespace:Minark.Client.Controls">

    <Border x:Name="RootBorder"
            CornerRadius="0"
            Background="{DynamicResource Surface2}"
            BorderBrush="{DynamicResource Border1}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <Border Grid.Row="0" CornerRadius="0"
                    Background="{DynamicResource Surface3}"
                    BorderBrush="{DynamicResource Border1}"
                    BorderThickness="0,0,0,1"
                    Padding="6,4">
                <StackPanel Orientation="Horizontal">
                    <ToggleButton x:Name="BoldBtn"
                                  Style="{StaticResource ToolbarToggle}"
                                  Click="Bold_Click"
                                  ToolTip="Gras (Ctrl+B)">
                        <TextBlock Text="B" FontSize="14" FontWeight="Bold"
                                   Foreground="{DynamicResource Text1}" />
                    </ToggleButton>
                    <ToggleButton x:Name="ItalicBtn"
                                  Style="{StaticResource ToolbarToggle}"
                                  Click="Italic_Click"
                                  ToolTip="Italique (Ctrl+I)">
                        <TextBlock Text="I" FontSize="14" FontStyle="Italic"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Text1}" />
                    </ToggleButton>
                    <ToggleButton x:Name="UnderlineBtn"
                                  Style="{StaticResource ToolbarToggle}"
                                  Click="Underline_Click"
                                  ToolTip="Souligné (Ctrl+U)">
                        <TextBlock Text="U" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Text1}">
                            <TextBlock.TextDecorations>
                                <TextDecoration Location="Underline" />
                            </TextBlock.TextDecorations>
                        </TextBlock>
                    </ToggleButton>
                    <ToggleButton x:Name="StrikeBtn"
                                  Style="{StaticResource ToolbarToggle}"
                                  Click="Strike_Click"
                                  ToolTip="Barré">
                        <TextBlock Text="S" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Text1}">
                            <TextBlock.TextDecorations>
                                <TextDecoration Location="Strikethrough" />
                            </TextBlock.TextDecorations>
                        </TextBlock>
                    </ToggleButton>

                    <Border Width="1" Margin="6,4" Background="{DynamicResource Border1}" />

                    <Button x:Name="BulletBtn"
                            Style="{StaticResource ToolbarBtn}"
                            Click="Bullet_Click"
                            ToolTip="Liste à puces">
                        <ui:FontIcon Glyph="&#xE8FD;" FontSize="13"
                                     Foreground="{DynamicResource Text1}" />
                    </Button>
                    <Button x:Name="NumberedBtn"
                            Style="{StaticResource ToolbarBtn}"
                            Click="Numbered_Click"
                            ToolTip="Liste numérotée">
                        <ui:FontIcon Glyph="&#xF2B7;" FontSize="13"
                                     Foreground="{DynamicResource Text1}" />
                    </Button>
                    <Button x:Name="QuoteBtn"
                            Style="{StaticResource ToolbarBtn}"
                            Click="Quote_Click"
                            ToolTip="Citation">
                        <ui:FontIcon Glyph="&#xE134;" FontSize="13"
                                     Foreground="{DynamicResource Text1}" />
                    </Button>

                    <Border Width="1" Margin="6,4" Background="{DynamicResource Border1}" />

                    <Button x:Name="EmojiBtn"
                            Style="{StaticResource ToolbarBtn}"
                            Click="Emoji_Click"
                            ToolTip="Emoji">
                        <ui:FontIcon Glyph="&#xE76E;" FontSize="14"
                                     Foreground="{DynamicResource Text1}" />
                    </Button>
                    <Button x:Name="ClearBtn"
                            Style="{StaticResource ToolbarBtn}"
                            Click="Clear_Click"
                            ToolTip="Effacer le formatage">
                        <ui:FontIcon Glyph="&#xE75C;" FontSize="13"
                                     Foreground="{DynamicResource Text2}" />
                    </Button>
                </StackPanel>
            </Border>

            <!-- Zone d'édition avec placeholder -->
            <Grid Grid.Row="1">
                <TextBlock x:Name="PlaceholderText"
                           Text="{Binding Placeholder, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           Foreground="{DynamicResource Text3}"
                           FontSize="13.5"
                           Margin="16,12,16,0"
                           IsHitTestVisible="False"
                           VerticalAlignment="Top" />

                <RichTextBox x:Name="Editor"
                             Style="{StaticResource EditorBox}"
                             MinHeight="80"
                             MaxHeight="260"
                             TextChanged="Editor_TextChanged"
                             SelectionChanged="Editor_SelectionChanged" />
            </Grid>

            <!-- Footer -->
            <Border Grid.Row="2" CornerRadius="0"
                    Background="{DynamicResource Surface3}"
                    BorderBrush="{DynamicResource Border1}"
                    BorderThickness="0,1,0,0"
                    Padding="12,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               x:Name="CharCounter"
                               Text="0 caractères"
                               FontSize="11"
                               Foreground="{DynamicResource Text3}"
                               VerticalAlignment="Center" />
                    <ContentPresenter Grid.Column="1"
                                      Content="{Binding ActionContent, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                </Grid>
            </Border>

            <Popup Grid.Row="0" x:Name="EmojiPopup"
                   PlacementTarget="{Binding ElementName=EmojiBtn}"
                   Placement="Bottom"
                   StaysOpen="False"
                   AllowsTransparency="True"
                   PopupAnimation="Fade">
                <Border CornerRadius="0"
                        Background="{DynamicResource Surface2}"
                        BorderBrush="{DynamicResource Border1}"
                        BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="24"
                                          ShadowDepth="0" Opacity="0.5" />
                    </Border.Effect>
                    <controls:EmojiPickerControl x:Name="EmojiPickerCtrl"
                                                 EmojiSelected="EmojiPicker_EmojiSelected" />
                </Border>
            </Popup>
        </Grid>
    </Border>
</UserControl>